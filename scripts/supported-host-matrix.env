# Canonical free-release host policy. This file is sourced by installers and
# copied into every release artifact.
AUTARK_OS_SUPPORTED_HOST_POLICY_VERSION="2"
AUTARK_OS_SUPPORTED_OS_IDS="debian ubuntu raspbian"
AUTARK_OS_SUPPORTED_DEBIAN_VERSIONS="12 13"
AUTARK_OS_SUPPORTED_UBUNTU_VERSIONS="24.04 26.04"
AUTARK_OS_SUPPORTED_RASPBIAN_VERSIONS="11 12 13"
AUTARK_OS_SUPPORTED_ARCHITECTURES="amd64 arm64"
AUTARK_OS_SUPPORTED_DEBIAN_ARCHITECTURES="amd64 arm64"
AUTARK_OS_SUPPORTED_UBUNTU_ARCHITECTURES="amd64 arm64"
AUTARK_OS_SUPPORTED_RASPBIAN_ARCHITECTURES="arm64"
AUTARK_OS_MIN_MEMORY_MB="2048"
AUTARK_OS_MIN_DISK_KB="10485760"
AUTARK_OS_REQUIRED_INIT="systemd"
AUTARK_OS_REQUIRED_CONTAINER_RUNTIME="docker-compose-v2"
AUTARK_OS_SUPPORTED_HOST_GUIDE="https://github.com/autark-labs/autark-os/blob/main/docs/technical-installation.md"
