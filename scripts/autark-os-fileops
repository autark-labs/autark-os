#!/usr/bin/env python3
"""Bounded privileged host operations for Autark-OS.

This helper is designed to be called through a narrow sudoers rule. It refuses
arbitrary paths and commands. File operations stay under the configured
Autark-OS runtime and approved backup roots; the sole host operation grants the fixed
Autark-OS service user permission to manage Tailscale Serve.
"""

from __future__ import annotations

import argparse
import grp
import os
from pathlib import Path
import pwd
import re
import shutil
import stat
import subprocess
import sys
import tempfile
import zipfile

APP_ID_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*$")
AUTARK_OS_SERVICE_USER = "autarkos"
TRUSTED_TAILSCALE_PATHS = (Path("/usr/bin/tailscale"), Path("/usr/local/bin/tailscale"))
# This is deliberately not configurable by environment. The helper runs with
# root privileges; allowing a caller to redirect its allow-list file would turn
# an otherwise bounded operation into an arbitrary-path approval mechanism.
DESTINATION_CONFIG = Path("/etc/autark-os/backup-destination.env")
RUNTIME_CONFIG = Path("/etc/autark-os/autark-os.env")
UNSUPPORTED_EXTERNAL_FILESYSTEMS = {"proc", "procfs", "sysfs", "devtmpfs", "tmpfs", "devpts", "cgroup", "cgroup2", "squashfs", "overlay", "ramfs"}
SYSTEM_ROOTS = (Path("/etc"), Path("/root"), Path("/usr"), Path("/bin"), Path("/sbin"), Path("/proc"), Path("/sys"), Path("/dev"), Path("/tmp"))


def die(message: str) -> None:
    print(f"autark-os-fileops: {message}", file=sys.stderr)
    raise SystemExit(1)


def resolved(path: str | Path) -> Path:
    return Path(path).expanduser().resolve(strict=False)


def require_inside(path: Path, root: Path, label: str) -> Path:
    try:
        path.relative_to(root)
    except ValueError:
        die(f"{label} must stay under {root}")
    return path


def path_is_inside(path: Path, root: Path) -> bool:
    try:
        path.relative_to(root)
        return True
    except ValueError:
        return False


def reject_symlink_segments(path: Path) -> None:
    current = path.anchor and Path(path.anchor) or Path("/")
    for part in path.parts[1:]:
        current = current / part
        if current.exists() and current.is_symlink():
            die("backup destinations cannot use symbolic links")


def mount_info(path: Path) -> tuple[Path, str, str]:
    """Return mount point, source device, and filesystem type for a real path."""
    target = path.resolve(strict=False)
    entries: list[tuple[Path, str, str]] = []
    try:
        for line in Path("/proc/self/mountinfo").read_text(encoding="utf-8").splitlines():
            left, separator, right = line.partition(" - ")
            if not separator:
                continue
            fields = left.split()
            right_fields = right.split()
            if len(fields) < 5 or len(right_fields) < 2:
                continue
            mount_point = Path(fields[4].replace("\\040", " ").replace("\\011", "\t"))
            entries.append((mount_point, right_fields[1], right_fields[0]))
    except OSError:
        entries = []
    matches = [entry for entry in entries if path_is_inside(target, entry[0])]
    if matches:
        return max(matches, key=lambda entry: len(entry[0].parts))
    return Path("/"), "unknown", "unknown"


def mount_identity(path: Path) -> str:
    mount_point, source, filesystem = mount_info(path)
    return f"{source}|{filesystem}|{mount_point}"


def read_destination_config() -> dict[str, str]:
    if not DESTINATION_CONFIG.is_file():
        return {}
    values: dict[str, str] = {}
    for line in DESTINATION_CONFIG.read_text(encoding="utf-8").splitlines():
        key, separator, value = line.partition("=")
        if separator:
            values[key.strip()] = value.strip()
    return values


def configured_runtime_root() -> Path | None:
    """Return the runtime root recorded by the root-owned installed config."""
    if not RUNTIME_CONFIG.is_file():
        return None
    for line in RUNTIME_CONFIG.read_text(encoding="utf-8").splitlines():
        key, separator, value = line.partition("=")
        if separator and key.strip() == "AUTARK_OS_RUNTIME_ROOT" and value.strip():
            return resolved(value.strip())
    die("installed service configuration does not define AUTARK_OS_RUNTIME_ROOT")


def require_configured_runtime_root(runtime_root: Path) -> Path:
    configured_root = configured_runtime_root()
    if configured_root is not None and runtime_root != configured_root:
        die("runtime root does not match this installed Autark-OS service")
    return runtime_root


def configured_roots() -> dict[Path, str]:
    values = read_destination_config()
    roots: dict[Path, str] = {}
    current = values.get("BACKUP_DESTINATION_PATH", "")
    current_identity = values.get("BACKUP_DESTINATION_MOUNT_IDENTITY", "")
    if current:
        roots[resolved(current)] = current_identity
    for item in values.get("BACKUP_DESTINATION_HISTORY", "").split(";"):
        path, separator, identity = item.partition("|")
        if separator and path:
            roots[resolved(path)] = identity
    return roots


def approved_backup_root(args: argparse.Namespace) -> Path:
    candidate = resolved(args.backup_root)
    internal = resolved(args.runtime_root / "backups")
    if candidate == internal:
        return candidate
    roots = configured_roots()
    expected_identity = roots.get(candidate)
    if not expected_identity:
        die("backup root is not an approved Autark-OS destination")
    if mount_identity(candidate) != expected_identity:
        die("the approved backup drive is missing or a different drive is mounted at this path")
    return candidate


def require_app_id(app_id: str) -> str:
    if not APP_ID_RE.match(app_id or ""):
        die("invalid app id")
    return app_id


def app_root(args: argparse.Namespace) -> Path:
    app_id = require_app_id(args.app)
    apps_root = resolved(args.runtime_root / "apps")
    # Resolve existing path segments before comparison so a symlinked app
    # folder cannot escape the managed runtime while this helper runs as root.
    return require_inside(resolved(apps_root / app_id), apps_root, "app runtime path")


def backup_path(args: argparse.Namespace, value: str, label: str = "backup path") -> Path:
    path = resolved(value)
    return require_inside(path, args.backup_root, label)


def probe_destination(path: Path) -> None:
    probe = path / f".autark-os-write-probe-{os.getpid()}-{os.urandom(4).hex()}"
    try:
        probe.write_text("Autark-OS backup destination probe\n", encoding="utf-8")
        if not probe.read_text(encoding="utf-8").startswith("Autark-OS backup destination probe"):
            die("backup destination did not return the validation probe")
    finally:
        probe.unlink(missing_ok=True)


def validate_external_destination(args: argparse.Namespace) -> tuple[Path, str]:
    destination = resolved(args.destination)
    if not destination.is_absolute() or destination == Path("/"):
        die("backup destination must be a dedicated absolute folder")
    if path_is_inside(destination, args.runtime_root):
        die("external backup destination cannot be inside the Autark-OS runtime")
    if any(path_is_inside(destination, root) for root in SYSTEM_ROOTS):
        die("external backup destination cannot be a system folder")
    reject_symlink_segments(destination)
    destination.mkdir(parents=True, exist_ok=True)
    mount_point, _source, filesystem = mount_info(destination)
    runtime_identity = mount_identity(args.runtime_root)
    identity = mount_identity(destination)
    if identity == runtime_identity:
        die("external backup destination must be on a different mounted filesystem")
    if filesystem.lower() in UNSUPPORTED_EXTERNAL_FILESYSTEMS:
        die(f"unsupported backup filesystem: {filesystem}")
    probe_destination(destination)
    return destination, identity


def configure_backup_destination(args: argparse.Namespace) -> None:
    internal = resolved(args.runtime_root / "backups")
    prior = configured_roots()
    history: dict[Path, str] = {}
    for path, previous_identity in prior.items():
        if path != resolved(args.destination) and previous_identity:
            history[path] = previous_identity
    for raw_path in args.history_root or []:
        path = resolved(raw_path)
        if path != resolved(args.destination) and path in prior:
            history[path] = prior[path]

    if resolved(args.destination) == internal:
        if not history:
            DESTINATION_CONFIG.unlink(missing_ok=True)
            print("cleared external backup destination; internal Autark-OS backups are active")
            return
        write_destination_config("", "", "", "", history)
        print("internal Autark-OS backups are active; previous external restore locations remain approved")
        return
    destination, identity = validate_external_destination(args)
    mount_point, _source, filesystem = mount_info(destination)
    write_destination_config(destination, identity, mount_point, filesystem, history)
    print(f"configured approved backup destination {destination}")


def write_destination_config(destination: str | Path, identity: str, mount_point: str | Path, filesystem: str, history: dict[Path, str]) -> None:
    history_value = ";".join(f"{path}|{stored_identity}" for path, stored_identity in history.items())
    DESTINATION_CONFIG.parent.mkdir(parents=True, exist_ok=True)
    temporary = DESTINATION_CONFIG.with_name(DESTINATION_CONFIG.name + ".tmp")
    temporary.write_text(
        "\n".join([
            "# Root-owned Autark-OS approved backup destination.",
            f"BACKUP_DESTINATION_PATH={destination}",
            f"BACKUP_DESTINATION_MOUNT_IDENTITY={identity}",
            f"BACKUP_DESTINATION_MOUNT_POINT={mount_point}",
            f"BACKUP_DESTINATION_FILESYSTEM={filesystem}",
            f"BACKUP_DESTINATION_HISTORY={history_value}",
            "",
        ]),
        encoding="utf-8",
    )
    os.chmod(temporary, 0o600)
    os.replace(temporary, DESTINATION_CONFIG)
    os.chmod(DESTINATION_CONFIG, 0o600)


def clear_contents(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True)
    for child in path.iterdir():
        if child.is_dir() and not child.is_symlink():
            shutil.rmtree(child)
        else:
            child.unlink(missing_ok=True)


def is_zip_symlink(info: zipfile.ZipInfo) -> bool:
    mode = info.external_attr >> 16
    return stat.S_IFMT(mode) == stat.S_IFLNK


def safe_archive_name(name: str) -> bool:
    candidate = Path(name)
    return bool(name) and not candidate.is_absolute() and ".." not in candidate.parts


def restore_app_data(args: argparse.Namespace) -> None:
    destination = app_root(args)
    archive = backup_path(args, args.archive, "restore archive")
    scope = args.scope or "app"
    destination.parent.mkdir(parents=True, exist_ok=True)
    staging = Path(tempfile.mkdtemp(prefix=".autark-os-restore-", dir=destination.parent))
    previous = destination.parent / f".{destination.name}.pre-restore-{os.getpid()}"
    moved_previous = False
    try:
        with zipfile.ZipFile(archive) as restore_zip:
            restored_files = 0
            for info in restore_zip.infolist():
                if info.is_dir():
                    continue
                if is_zip_symlink(info):
                    die(f"restore archive contains unsupported symlink: {info.filename}")
                name = info.filename
                if scope == "full":
                    prefix = f"{args.app}/"
                    if not name.startswith(prefix):
                        continue
                    name = name[len(prefix):]
                if not safe_archive_name(name):
                    die(f"restore archive contains unsafe path: {info.filename}")
                target = require_inside(staging / name, staging, "restore target")
                target.parent.mkdir(parents=True, exist_ok=True)
                with restore_zip.open(info) as source, target.open("wb") as output:
                    shutil.copyfileobj(source, output)
                restored_files += 1
        if restored_files == 0:
            die("restore archive does not contain restorable app data")
        if destination.exists():
            os.replace(destination, previous)
            moved_previous = True
        os.replace(staging, destination)
        if moved_previous:
            shutil.rmtree(previous)
    except Exception:
        if moved_previous and not destination.exists() and previous.exists():
            os.replace(previous, destination)
        raise
    finally:
        if staging.exists():
            shutil.rmtree(staging)
    print(f"restored {args.app}")


def clear_runtime(args: argparse.Namespace) -> None:
    clear_contents(app_root(args))
    print(f"cleared {args.app}")


def create_safety_archive(args: argparse.Namespace) -> None:
    source = app_root(args)
    destination = backup_path(args, args.destination, "archive destination")
    if destination.suffix != ".zip":
        die("archive destination must be a .zip file")
    destination.parent.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(destination, "w", compression=zipfile.ZIP_DEFLATED) as archive:
        if source.exists():
            for path in source.rglob("*"):
                if path.is_symlink() or not path.is_file():
                    continue
                archive.write(path, path.relative_to(source).as_posix())
    print(f"archived {args.app}")


def create_full_archive(args: argparse.Namespace) -> None:
    destination = backup_path(args, args.destination, "archive destination")
    if destination.suffix != ".zip":
        die("archive destination must be a .zip file")
    app_ids = [require_app_id(app.strip()) for app in (args.apps or "").split(",") if app.strip()]
    if not app_ids:
        die("--apps must include at least one app id")
    destination.parent.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(destination, "w", compression=zipfile.ZIP_DEFLATED) as archive:
        for app_id in app_ids:
            source = app_root(argparse.Namespace(runtime_root=args.runtime_root, app=app_id))
            if not source.exists():
                continue
            for path in source.rglob("*"):
                if path.is_symlink() or not path.is_file():
                    continue
                relative = Path(app_id) / path.relative_to(source)
                archive.write(path, relative.as_posix())
    print(f"archived {','.join(app_ids)}")


def delete_backup(args: argparse.Namespace) -> None:
    path = backup_path(args, args.path)
    if path.suffix != ".zip":
        die("only .zip backup files can be deleted")
    if path.is_dir():
        die("backup path is a directory")
    path.unlink(missing_ok=True)
    print(f"deleted {path}")


def repair_runtime_ownership(args: argparse.Namespace) -> None:
    if args.user != AUTARK_OS_SERVICE_USER or args.group != AUTARK_OS_SERVICE_USER:
        die("runtime ownership can only be repaired for the autarkos service user")
    root = app_root(args)
    uid = pwd.getpwnam(args.user).pw_uid
    gid = grp.getgrnam(args.group).gr_gid
    for current_root, directories, files in os.walk(root, followlinks=False):
        os.chown(current_root, uid, gid)
        for name in directories + files:
            path = Path(current_root) / name
            if path.is_symlink():
                continue
            os.chown(path, uid, gid)
    print(f"repaired ownership for {args.app}")


def configure_tailscale_operator(_args: argparse.Namespace) -> None:
    tailscale = next((path for path in TRUSTED_TAILSCALE_PATHS if path.is_file() and os.access(path, os.X_OK)), None)
    if tailscale is None:
        die("tailscale was not found in a trusted system location")
    result = subprocess.run(
        [str(tailscale), "set", f"--operator={AUTARK_OS_SERVICE_USER}"],
        check=False,
        capture_output=True,
        text=True,
        env={"PATH": "/usr/sbin:/usr/bin:/sbin:/bin", "HOME": "/root", "LANG": "C"},
    )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "tailscale returned no details").strip()
        die(f"could not configure Tailscale Serve permission: {detail}")
    print(f"configured Tailscale operator for {AUTARK_OS_SERVICE_USER}")


def parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Autark-OS bounded file operations")
    parser.add_argument("operation", choices=[
        "clear-runtime",
        "restore-app-data",
        "create-safety-archive",
        "create-full-archive",
        "delete-backup",
        "repair-runtime-ownership",
        "configure-tailscale-operator",
        "configure-backup-destination",
    ])
    parser.add_argument("--runtime-root")
    parser.add_argument("--backup-root")
    parser.add_argument("--app")
    parser.add_argument("--archive")
    parser.add_argument("--scope", choices=["app", "full"], default="app")
    parser.add_argument("--destination")
    parser.add_argument("--apps")
    parser.add_argument("--path")
    parser.add_argument("--user")
    parser.add_argument("--group")
    parser.add_argument("--destination-identity")
    parser.add_argument("--destination-filesystem")
    parser.add_argument("--destination-mount-point")
    parser.add_argument("--history-root", action="append")
    return parser


def main(argv: list[str]) -> int:
    args = parser().parse_args(argv)
    if args.operation == "configure-tailscale-operator":
        configure_tailscale_operator(args)
        return 0
    if not args.runtime_root or not args.backup_root:
        die("--runtime-root and --backup-root are required for file operations")
    args.runtime_root = resolved(args.runtime_root)
    args.runtime_root = require_configured_runtime_root(args.runtime_root)
    if args.operation == "configure-backup-destination":
        if not args.destination:
            die("--destination is required")
        configure_backup_destination(args)
        return 0
    args.backup_root = approved_backup_root(args)
    if args.operation in {"clear-runtime", "restore-app-data", "create-safety-archive", "repair-runtime-ownership"} and not args.app:
        die("--app is required")
    if args.operation == "restore-app-data" and not args.archive:
        die("--archive is required")
    if args.operation == "create-safety-archive" and not args.destination:
        die("--destination is required")
    if args.operation == "create-full-archive" and (not args.apps or not args.destination):
        die("--apps and --destination are required")
    if args.operation == "delete-backup" and not args.path:
        die("--path is required")
    if args.operation == "repair-runtime-ownership" and (not args.user or not args.group):
        die("--user and --group are required")

    operations = {
        "clear-runtime": clear_runtime,
        "restore-app-data": restore_app_data,
        "create-safety-archive": create_safety_archive,
        "create-full-archive": create_full_archive,
        "delete-backup": delete_backup,
        "repair-runtime-ownership": repair_runtime_ownership,
    }
    operations[args.operation](args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
