#!/usr/bin/env bash
set -euo pipefail

SERVICE_NAME="${AUTARK_OS_SERVICE_NAME:-autark-os}"
BASE_URL_OVERRIDE="${AUTARK_OS_BASE_URL:-}"
CONFIG_FILE="${AUTARK_OS_CONFIG_FILE:-/etc/autark-os/autark-os.env}"
DEFAULT_PORT="${AUTARK_OS_DEFAULT_PORT:-8082}"
SCRIPT_PATH="${BASH_SOURCE[0]}"
has_readlink_path="$(command -v readlink 2>/dev/null || true)"
if [[ -n "${has_readlink_path}" ]]; then
  SCRIPT_PATH="$("${has_readlink_path}" -f "${SCRIPT_PATH}" 2>/dev/null || printf '%s' "${SCRIPT_PATH}")"
fi
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
SERVICE_FILE="${AUTARK_OS_SERVICE_FILE:-/etc/systemd/system/${SERVICE_NAME}.service}"
CLI_LINK="${AUTARK_OS_CLI_LINK:-/usr/local/bin/autark-os}"
SUDOERS_FILE="${AUTARK_OS_SUDOERS_FILE:-/etc/sudoers.d/autark-os-fileops}"
UPDATE_REPOSITORY="${AUTARK_OS_UPDATE_REPOSITORY:-autark-labs/autark-os}"
UPDATE_API_VERSION="${AUTARK_OS_GITHUB_API_VERSION:-2022-11-28}"
UPDATE_HEALTH_TIMEOUT="${AUTARK_OS_UPDATE_HEALTH_TIMEOUT:-120}"
PUBLIC_INSTALL_METADATA="${AUTARK_OS_PUBLIC_INSTALL_METADATA:-${SCRIPT_DIR}/../release-metadata/install.env}"
ADMIN_TOKEN="${AUTARK_OS_ADMIN_TOKEN:-}"

usage() {
  cat <<USAGE
Usage: autark-os <command>

Commands:
  install    Install Autark-OS or print a shared install plan.
  doctor     Check host setup, service health, and core API readiness. Use --json for scripts.
  setup      Start or resume the first-boot setup flow.
  admin      Show the local setup code or reset the administrator password.
  repair     Check installed Autark-OS and print recovery actions.
  update     Run the unified Autark-OS update flow or one scoped stage.
  uninstall  Remove Autark-OS service paths through the guided uninstall flow.
  support-bundle
             Export redacted installer/setup diagnostics for support.
  where      Show install, runtime, config, log, service, and helper paths.
  status     Show systemd status for ${SERVICE_NAME}.service.
  logs       Show recent backend logs. Add --follow to keep watching.
  start      Start ${SERVICE_NAME}.service.
  stop       Stop ${SERVICE_NAME}.service.
  restart    Restart ${SERVICE_NAME}.service.
  version    Print Autark-OS version, build, install path, and runtime path.
  port       Print the configured Autark-OS service port.
  url        Print the local Autark-OS URL.
  help       Show this help.

Environment:
  AUTARK_OS_SERVICE_NAME  Override the systemd service name.
  AUTARK_OS_BASE_URL      Override the local API URL.
  AUTARK_OS_CONFIG_FILE   Override the service env file. Defaults to /etc/autark-os/autark-os.env.
  AUTARK_OS_DEFAULT_PORT  Fallback port when config cannot be read. Defaults to 8082.
USAGE
}

log() {
  printf '[autark-os] %s\n' "$*"
}

die() {
  printf '[autark-os] error: %s\n' "$*" >&2
  exit 1
}

has_command() {
  command -v "$1" >/dev/null 2>&1
}

logs_command() {
  local lines=200
  local follow=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --follow|-f)
        follow=1
        ;;
      --lines)
        shift
        [[ $# -gt 0 ]] || die "--lines requires a number."
        lines="$1"
        ;;
      --lines=*)
        lines="${1#*=}"
        ;;
      -h|--help)
        cat <<LOGS_USAGE
Usage: autark-os logs [options]

Show recent Autark-OS backend service messages.

Options:
  --lines NUMBER  Number of recent messages to show. Default: 200.
  --follow, -f    Continue watching for new messages. Press Ctrl+C to stop.
  -h, --help      Show this help.
LOGS_USAGE
        return 0
        ;;
      *)
        die "Unknown logs option: $1"
        ;;
    esac
    shift
  done
  [[ "${lines}" =~ ^[1-9][0-9]*$ ]] || die "--lines must be a positive number: ${lines}"

  local journal_args=(-u "${SERVICE_NAME}.service" --no-pager -n "${lines}")
  [[ "${follow}" -eq 0 ]] || journal_args+=(-f)
  if [[ "$(id -u)" -eq 0 ]]; then
    journalctl "${journal_args[@]}"
  else
    has_command sudo || die "Reading system service logs requires administrator access. Install sudo or run this command as root."
    sudo journalctl "${journal_args[@]}"
  fi
}

configured_value() {
  local key="$1"
  if [[ -r "${CONFIG_FILE}" ]]; then
    awk -F= -v key="${key}" '$1 == key {print $2; exit}' "${CONFIG_FILE}"
  fi
}

public_install_value() {
  local key="$1"
  awk -F= -v key="${key}" '$1 == key {print $2; exit}' "${PUBLIC_INSTALL_METADATA}" 2>/dev/null || true
}

systemd_environment_value() {
  local key="$1"
  has_command systemctl || return 0
  systemctl show "${SERVICE_NAME}.service" -p Environment --value 2>/dev/null \
    | tr ' ' '\n' \
    | awk -F= -v key="${key}" '$1 == key {print $2; exit}'
}

port_from_base_url() {
  local value="$1"
  [[ "${value}" =~ :([0-9]+)(/|$) ]] || return 0
  printf '%s\n' "${BASH_REMATCH[1]}"
}

resolve_port() {
  local port=""
  if [[ -n "${BASE_URL_OVERRIDE}" ]]; then
    port="$(port_from_base_url "${BASE_URL_OVERRIDE}")"
  fi
  [[ -n "${port}" ]] || port="$(configured_value SERVER_PORT)"
  [[ -n "${port}" ]] || port="$(systemd_environment_value SERVER_PORT)"
  [[ -n "${port}" ]] || port="${DEFAULT_PORT}"
  printf '%s\n' "${port}"
}

resolve_base_url() {
  if [[ -n "${BASE_URL_OVERRIDE}" ]]; then
    printf '%s\n' "${BASE_URL_OVERRIDE}"
    return 0
  fi
  printf 'http://localhost:%s\n' "$(resolve_port)"
}

api_get() {
  local path="$1"
  local base_url
  base_url="$(resolve_base_url)"
  local headers=()
  local header_file="" exit_code=0
  case "${path}" in
    /api/health|/api/admin/security/status) ;;
    *)
      ensure_admin_session
      if [[ -n "${ADMIN_TOKEN}" ]]; then
        header_file="$(admin_header_file)"
        headers+=(-H "@${header_file}")
      fi
      ;;
  esac
  curl -fsS "${headers[@]}" "${base_url}${path}" || exit_code=$?
  [[ -z "${header_file}" ]] || rm -f "${header_file}"
  return "${exit_code}"
}

admin_token_cache_file() {
  if [[ -n "${AUTARK_OS_ADMIN_TOKEN_FILE:-}" ]]; then
    printf '%s\n' "${AUTARK_OS_ADMIN_TOKEN_FILE}"
    return 0
  fi
  local cache_root="${XDG_CACHE_HOME:-${HOME:-/tmp}/.cache}"
  printf '%s/autark-os/admin-token\n' "${cache_root}"
}

load_cached_admin_token() {
  [[ -n "${ADMIN_TOKEN}" ]] && return 0
  local token_file
  token_file="$(admin_token_cache_file)"
  if [[ -r "${token_file}" ]]; then
    ADMIN_TOKEN="$(head -n 1 "${token_file}" 2>/dev/null || true)"
  fi
}

clear_cached_admin_token() {
  ADMIN_TOKEN=""
  rm -f "$(admin_token_cache_file)" 2>/dev/null || true
}

save_cached_admin_token() {
  local token_file
  token_file="$(admin_token_cache_file)"
  mkdir -p "$(dirname "${token_file}")"
  chmod 700 "$(dirname "${token_file}")" 2>/dev/null || true
  umask 077
  printf '%s\n' "${ADMIN_TOKEN}" >"${token_file}"
  chmod 600 "${token_file}" 2>/dev/null || true
}

admin_session_is_valid() {
  [[ -n "${ADMIN_TOKEN}" ]] || return 1
  local base_url response header_file
  base_url="$(resolve_base_url)"
  header_file="$(admin_header_file)"
  response="$(curl -fsS -H "@${header_file}" "${base_url}/api/admin/security/session" 2>/dev/null || true)"
  rm -f "${header_file}"
  [[ "${response}" == *'"authorized":true'* ]]
}

admin_header_file() {
  local header_file
  header_file="$(mktemp)"
  chmod 600 "${header_file}" 2>/dev/null || true
  printf 'Authorization: Bearer %s\n' "${ADMIN_TOKEN}" >"${header_file}"
  printf '%s\n' "${header_file}"
}

read_admin_secret() {
  local prompt="$1"
  local environment_value="${2:-}"
  if [[ -n "${environment_value}" ]]; then
    printf '%s' "${environment_value}"
    return 0
  fi
  [[ -r /dev/tty ]] || die "Admin login is required. Rerun interactively or provide AUTARK_OS_ADMIN_TOKEN."
  local value
  printf '%s' "${prompt}" >/dev/tty
  IFS= read -r -s value </dev/tty
  printf '\n' >/dev/tty
  printf '%s' "${value}"
}

ensure_admin_session() {
  load_cached_admin_token
  if admin_session_is_valid; then
    return 0
  fi
  clear_cached_admin_token

  local base_url status_file response_file claimed auth_required password confirmation request_path body http_status token
  base_url="$(resolve_base_url)"
  status_file="$(mktemp)"
  response_file="$(mktemp)"
  if ! curl -fsS "${base_url}/api/admin/security/status" >"${status_file}"; then
    rm -f "${status_file}" "${response_file}"
    die "Autark-OS could not check admin access at ${base_url}."
  fi
  auth_required="$(json_bool authRequired "${status_file}")"
  if [[ "${auth_required}" != "true" ]]; then
    rm -f "${status_file}" "${response_file}"
    return 0
  fi

  claimed="$(json_bool claimed "${status_file}")"
  password="$(read_admin_secret "Admin password: " "${AUTARK_OS_ADMIN_PASSWORD:-}")"
  if [[ "${claimed}" == "true" ]]; then
    request_path="/api/admin/security/login"
    body="{\"password\":\"$(json_escape "${password}")\"}"
  else
    if [[ -n "${AUTARK_OS_ADMIN_SETUP_CODE:-}" ]]; then
      confirmation="${AUTARK_OS_ADMIN_SETUP_CODE}"
    else
      printf 'Get the local setup code in another terminal with:\n  sudo autark-os admin setup-code\n' >/dev/tty
      printf 'Setup code: ' >/dev/tty
      IFS= read -r confirmation </dev/tty
    fi
    request_path="/api/admin/security/claim"
    body="{\"setupCode\":\"$(json_escape "${confirmation}")\",\"password\":\"$(json_escape "${password}")\"}"
  fi

  http_status="$(printf '%s' "${body}" | curl -sS -o "${response_file}" -w '%{http_code}' -X POST -H 'Content-Type: application/json' -H 'X-Autark-OS-Client: cli' --data-binary @- "${base_url}${request_path}" || true)"
  token="$(json_value token "${response_file}")"
  if [[ "${http_status}" != "200" || -z "${token}" ]]; then
    local message
    message="$(json_value message "${response_file}")"
    rm -f "${status_file}" "${response_file}"
    die "${message:-Autark-OS admin login was not accepted.}"
  fi
  ADMIN_TOKEN="${token}"
  save_cached_admin_token
  rm -f "${status_file}" "${response_file}"
}

api_post() {
  local path="$1"
  local body="${2:-{}}"
  local base_url
  ensure_admin_session
  base_url="$(resolve_base_url)"
  local headers=(-H 'Content-Type: application/json')
  local header_file="" exit_code=0
  if [[ -n "${ADMIN_TOKEN}" ]]; then
    header_file="$(admin_header_file)"
    headers+=(-H "@${header_file}")
  fi
  printf '%s' "${body}" | curl -fsS -X POST "${headers[@]}" --data-binary @- "${base_url}${path}" || exit_code=$?
  [[ -z "${header_file}" ]] || rm -f "${header_file}"
  return "${exit_code}"
}

api_put() {
  local path="$1"
  local body="$2"
  local base_url
  ensure_admin_session
  base_url="$(resolve_base_url)"
  local headers=(-H 'Content-Type: application/json')
  local header_file="" exit_code=0
  if [[ -n "${ADMIN_TOKEN}" ]]; then
    header_file="$(admin_header_file)"
    headers+=(-H "@${header_file}")
  fi
  printf '%s' "${body}" | curl -fsS -X PUT "${headers[@]}" --data-binary @- "${base_url}${path}" || exit_code=$?
  [[ -z "${header_file}" ]] || rm -f "${header_file}"
  return "${exit_code}"
}

api_delete() {
  local path="$1"
  local base_url
  ensure_admin_session
  base_url="$(resolve_base_url)"
  local headers=()
  local header_file="" exit_code=0
  if [[ -n "${ADMIN_TOKEN}" ]]; then
    header_file="$(admin_header_file)"
    headers+=(-H "@${header_file}")
  fi
  curl -fsS -X DELETE "${headers[@]}" "${base_url}${path}" || exit_code=$?
  [[ -z "${header_file}" ]] || rm -f "${header_file}"
  return "${exit_code}"
}

json_value() {
  local key="$1"
  local file="$2"
  sed -nE "s/.*\"${key}\"[[:space:]]*:[[:space:]]*\"([^\"]*)\".*/\\1/p" "${file}" | head -n 1
}

json_bool() {
  local key="$1"
  local file="$2"
  sed -nE "s/.*\"${key}\"[[:space:]]*:[[:space:]]*(true|false).*/\\1/p" "${file}" | head -n 1
}

json_array_strings() {
  local key="$1"
  local file="$2"
  sed -nE "s/.*\"${key}\"[[:space:]]*:[[:space:]]*\\[([^]]*)\\].*/\\1/p" "${file}" \
    | head -n 1 \
    | tr ',' '\n' \
    | sed -E 's/^[[:space:]]*"//; s/"[[:space:]]*$//; /^$/d'
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

json_string() {
  printf '"%s"' "$(json_escape "$1")"
}

json_string_array() {
  local first=1
  printf '['
  for value in "$@"; do
    if [[ "${first}" -eq 0 ]]; then
      printf ','
    fi
    first=0
    json_string "${value}"
  done
  printf ']'
}

file_url_path() {
  local value="$1"
  case "${value}" in
    file://*) printf '%s\n' "${value#file://}" ;;
    *) printf '%s\n' "${value}" ;;
  esac
}

json_list() {
  local first=1
  printf '['
  for value in "$@"; do
    if [[ "${first}" -eq 0 ]]; then
      printf ','
    fi
    first=0
    printf '"%s"' "$(json_escape "${value}")"
  done
  printf ']'
}

read_default() {
  local prompt="$1"
  local default_value="$2"
  local value
  if [[ -n "${default_value}" ]]; then
    read -r -p "${prompt} [${default_value}]: " value
    printf '%s\n' "${value:-${default_value}}"
  else
    read -r -p "${prompt}: " value
    printf '%s\n' "${value}"
  fi
}

confirm_default_yes() {
  local prompt="$1"
  local value
  read -r -p "${prompt} [Y/n]: " value
  case "${value,,}" in
    n|no) return 1 ;;
    *) return 0 ;;
  esac
}

confirm_default_no() {
  local prompt="$1"
  local value
  read -r -p "${prompt} [y/N]: " value
  case "${value,,}" in
    y|yes) return 0 ;;
    *) return 1 ;;
  esac
}

print_setup_next_step() {
  local base_url
  base_url="$(resolve_base_url)"
  log "Open Autark-OS: ${base_url}"
  log "First-time setup code: sudo autark-os admin setup-code"
  log "Run 'autark-os doctor' if the page is not reachable."
}

installed_runtime_root() {
  local value=""
  value="$(configured_value AUTARK_OS_RUNTIME_ROOT)"
  [[ -n "${value}" ]] || value="/var/lib/autark-os"
  printf '%s\n' "${value}"
}

require_local_root() {
  [[ "$(id -u)" -eq 0 ]] || die "This local recovery command requires root approval. Rerun it with sudo."
}

admin_setup_code_command() {
  require_local_root
  local setup_code_file
  setup_code_file="$(installed_runtime_root)/config/admin-setup-code"
  if [[ ! -r "${setup_code_file}" ]]; then
    die "No local setup code is available. If this appliance is already claimed, use 'sudo autark-os admin reset-password'. If it is new, make sure the service is running and retry."
  fi
  head -n 1 "${setup_code_file}"
}

admin_reset_password_command() {
  require_local_root
  local runtime_root local_secret_file local_secret password confirmation base_url response_file header_file body http_status
  runtime_root="$(installed_runtime_root)"
  local_secret_file="${runtime_root}/config/admin-local-secret"
  [[ -r "${local_secret_file}" ]] || die "The local administrator recovery credential is missing. Start or repair Autark-OS, then retry."
  local_secret="$(head -n 1 "${local_secret_file}" 2>/dev/null || true)"
  [[ -n "${local_secret}" ]] || die "The local administrator recovery credential is empty. Repair Autark-OS, then retry."

  password="$(read_admin_secret "New admin password: " "${AUTARK_OS_ADMIN_NEW_PASSWORD:-}")"
  if [[ -n "${AUTARK_OS_ADMIN_NEW_PASSWORD_CONFIRMATION:-}" ]]; then
    confirmation="${AUTARK_OS_ADMIN_NEW_PASSWORD_CONFIRMATION}"
  else
    confirmation="$(read_admin_secret "Confirm new admin password: ")"
  fi
  [[ "${password}" == "${confirmation}" ]] || die "The administrator password confirmation did not match. No changes were made."
  [[ "${#password}" -ge 12 ]] || die "Use an administrator password with at least 12 characters. No changes were made."

  base_url="http://127.0.0.1:$(resolve_port)"
  response_file="$(mktemp)"
  header_file="$(mktemp)"
  chmod 600 "${response_file}" "${header_file}" 2>/dev/null || true
  printf 'X-Autark-OS-Local-Secret: %s\n' "${local_secret}" >"${header_file}"
  body="{\"password\":\"$(json_escape "${password}")\"}"
  http_status="$(printf '%s' "${body}" | curl -sS -o "${response_file}" -w '%{http_code}' -X POST -H 'Content-Type: application/json' -H "@${header_file}" --data-binary @- "${base_url}/api/admin/security/local/reset-password" || true)"
  rm -f "${header_file}"
  if [[ "${http_status}" != "200" || "$(json_bool ok "${response_file}")" != "true" ]]; then
    local message
    message="$(json_value message "${response_file}")"
    rm -f "${response_file}"
    die "${message:-Autark-OS could not reset the administrator password. Check 'autark-os status' and retry.}"
  fi
  rm -f "${response_file}"
  clear_cached_admin_token
  log "Administrator password reset. All active sessions were revoked; log in again with the new password."
  log "Apps, settings, and backups were preserved."
}

admin_command() {
  case "${1:-help}" in
    setup-code)
      shift || true
      [[ $# -eq 0 ]] || die "Usage: autark-os admin setup-code"
      admin_setup_code_command
      ;;
    reset-password)
      shift || true
      [[ $# -eq 0 ]] || die "Usage: autark-os admin reset-password"
      admin_reset_password_command
      ;;
    help|-h|--help)
      cat <<ADMIN_USAGE
Usage: autark-os admin <command>

Local administrator recovery commands:
  setup-code      Print the first-run claim code. Requires sudo/root.
  reset-password  Set a new administrator password and revoke sessions. Requires sudo/root.

These commands operate only through local root-readable credentials. They do
not delete apps, settings, backups, Docker state, or the Tailscale identity.
ADMIN_USAGE
      ;;
    *)
      die "Unknown admin command: ${1}. Run 'autark-os admin --help'."
      ;;
  esac
}

bootstrap_installer() {
  if [[ -x "${SCRIPT_DIR}/bootstrap-autark-os.sh" ]]; then
    printf '%s\n' "${SCRIPT_DIR}/bootstrap-autark-os.sh"
    return 0
  fi
  if [[ -x "$(pwd)/scripts/bootstrap-autark-os.sh" ]]; then
    printf '%s\n' "$(pwd)/scripts/bootstrap-autark-os.sh"
    return 0
  fi
  return 1
}

running_from_release_bundle() {
  [[ -r "${SCRIPT_DIR}/../autark-os-release.json" && -d "${SCRIPT_DIR}/../backend" ]]
}

has_install_artifact_arg() {
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --release-bundle|--release-bundle=*|--release-jar|--release-jar=*)
        return 0
        ;;
    esac
  done
  return 1
}

has_arg() {
  local needle="$1"
  shift
  local arg
  for arg in "$@"; do
    [[ "${arg}" == "${needle}" ]] && return 0
  done
  return 1
}

has_prefixed_arg() {
  local needle="$1"
  shift
  local arg
  for arg in "$@"; do
    [[ "${arg}" == "${needle}" || "${arg}" == "${needle}="* ]] && return 0
  done
  return 1
}

release_bundle_arg() {
  local previous="" arg
  for arg in "$@"; do
    if [[ "${previous}" == "--release-bundle" ]]; then
      printf '%s\n' "${arg}"
      return 0
    fi
    case "${arg}" in
      --release-bundle=*)
        printf '%s\n' "${arg#*=}"
        return 0
        ;;
    esac
    previous="${arg}"
  done
  return 1
}

verify_release_bundle_checksums() {
  local bundle_dir="$1"
  log "Verifying release bundle checksums."
  verify_release_bundle "${bundle_dir}"
}

install_command() {
  local guided=0
  local yes=0
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --guided)
        guided=1
        ;;
      --yes)
        yes=1
        ;;
      -h|--help)
        cat <<INSTALL_USAGE
Usage: autark-os install [options]

Examples:
  autark-os install
  autark-os install --guided
  autark-os install --plan --json
  autark-os install --release-bundle /path/to/autark-os-release

Routes to bootstrap-autark-os.sh so portable and installed CLI flows share
the same pre-install doctor, plan, dependency, and service installer logic.

Common options:
  --guided             Use the interactive installer surface. Default for normal installs.
  --plan               Print the install plan without changing the host.
  --doctor             Check whether this host is ready before installing.
  --json               With --plan or --doctor, print JSON.
  --dry-run            Preview install actions without changing the host.
  --yes                Confirm guided prompts where supported.
  --auto-install-deps  Install supported host dependencies.
  --release-bundle DIR Install from a packaged release bundle.
  --release-jar FILE   Install this backend jar.
  --runtime-dir DIR    Store runtime data in DIR.
  --port PORT          Run Autark-OS on PORT.
  -h, --help           Show this help.
INSTALL_USAGE
        return 0
        ;;
      *)
        args+=("$1")
        ;;
    esac
    shift
  done

  local installer
  if ! installer="$(bootstrap_installer)"; then
    log "Portable installer files were not found next to this autark-os command."
    log "Run from a release bundle, or use ./scripts/bootstrap-autark-os.sh from the source checkout."
    return 1
  fi

  local bundle_dir=""
  if ! has_install_artifact_arg "${args[@]}" && running_from_release_bundle; then
    bundle_dir="$(cd "${SCRIPT_DIR}/.." && pwd)"
    args=(--release-bundle "${bundle_dir}" "${args[@]}")
  else
    bundle_dir="$(release_bundle_arg "${args[@]}" || true)"
  fi

  local machine_output=0
  if has_arg "--json" "${args[@]}"; then
    machine_output=1
  fi

  local metadata_only=0
  if has_arg "--plan" "${args[@]}" || has_arg "--doctor" "${args[@]}"; then
    metadata_only=1
  fi

  if [[ "${metadata_only}" -eq 0 && "${machine_output}" -eq 0 ]]; then
    guided=1
  fi

  if [[ "${guided}" -eq 1 && "${metadata_only}" -eq 0 ]]; then
    if ! has_prefixed_arg "--auto-install-deps" "${args[@]}"; then
      args+=(--auto-install-deps)
      [[ "${machine_output}" -eq 1 ]] || log "Installing missing supported dependencies by default for the guided install."
    fi
    if [[ "${machine_output}" -eq 0 ]]; then
      log "Unified guided install"
      log "This command will check this host, request administrator approval once, install supported dependencies when needed, install Autark-OS, and start the service."
      log "Use 'autark-os install --plan' or 'autark-os install --dry-run' to preview without installing."
    fi
  elif [[ "${guided}" -eq 1 && "${machine_output}" -eq 0 ]]; then
    log "Guided install uses the shared installer. Review each prompt or run with --plan first."
  fi

  if [[ -n "${bundle_dir}" && "${machine_output}" -eq 0 ]]; then
    verify_release_bundle_checksums "${bundle_dir}"
  fi
  local dry_run_install=0
  if has_arg "--dry-run" "${args[@]}"; then
    dry_run_install=1
  fi
  if [[ "${guided}" -eq 1 && "${metadata_only}" -eq 0 && "${machine_output}" -eq 0 && "${dry_run_install}" -eq 0 && "${yes}" -eq 0 ]]; then
    log "Install Autark-OS and supported dependencies on this host?"
    if ! confirm_default_no "Install Autark-OS and supported dependencies on this host?"; then
      log "Installation cancelled."
      return 1
    fi
  fi

  local env_args=()
  if [[ -n "${bundle_dir}" && "${machine_output}" -eq 0 ]]; then
    env_args+=("AUTARK_OS_RELEASE_VERIFIED=1" "AUTARK_OS_INSTALL_METHOD=${AUTARK_OS_INSTALL_METHOD:-release-bundle}")
  fi
  env "${env_args[@]}" "${installer}" "${args[@]}"
}

repair_command() {
  local plan=0 apply=0
  if [[ "${1:-}" == "--plan" ]]; then plan=1; shift; fi
  if [[ "${1:-}" == "--apply" ]]; then apply=1; shift; fi
  case "${1:-}" in
    -h|--help)
      cat <<REPAIR_USAGE
Usage: autark-os repair [options]

Checks installed Autark-OS and offers a reviewed repair plan.

Options:
  --plan     Print the repair plan without changing the host.
  --apply    Reinstall service configuration and helper files, then verify.
  --json     Print doctor JSON when the backend is reachable.
  -h, --help Show this help.
REPAIR_USAGE
      return 0
      ;;
  esac

  local install_dir repair_script
  install_dir="$(configured_value AUTARK_OS_INSTALL_DIR)"
  [[ -n "${install_dir}" ]] || install_dir="/opt/autark-os"
  repair_script="${install_dir}/bin/install-autark-os-service.sh"
  if [[ "${plan}" -eq 1 ]]; then
    log "Repair plan: verify ${SERVICE_NAME}.service, bundled runtime, helper files, and Docker access."
    log "Apply: sudo ${repair_script}"
    return 0
  fi
  if [[ "${apply}" -eq 1 ]]; then
    [[ -x "${repair_script}" ]] || die "Repair installer is missing: ${repair_script}. Reinstall the current package or release bundle."
    log "Applying repair plan. Existing runtime app data is preserved."
    sudo "${repair_script}"
    doctor || die "Repair applied, but verification still needs attention. Run 'autark-os logs' and retry."
    log "Repair verified."
    return 0
  fi

  log "Checking installed Autark-OS before repair."
  if doctor "$@"; then
    log "No automatic repair action is required by this helper."
    return 0
  fi
  log "Recovery actions:"
  log "  autark-os status"
  log "  autark-os logs"
  log "  autark-os restart"
  return 1
}

installed_version() {
  local value=""
  value="$(configured_value AUTARK_OS_VERSION)"
  [[ -n "${value}" ]] || value="$(awk -F= '$1 == "AUTARK_OS_VERSION" {print $2; exit}' "${PUBLIC_INSTALL_METADATA}" 2>/dev/null || true)"
  if [[ -z "${value}" ]]; then
    local response
    response="$(mktemp)"
    if api_get /api/system/version >"${response}" 2>/dev/null; then
      value="$(json_value version "${response}")"
    fi
    rm -f "${response}"
  fi
  printf '%s\n' "${value:-unknown}"
}

installed_channel() {
  local value=""
  value="$(configured_value AUTARK_OS_UPDATE_CHANNEL)"
  [[ -n "${value}" ]] || value="$(awk -F= '$1 == "AUTARK_OS_UPDATE_CHANNEL" {print $2; exit}' "${PUBLIC_INSTALL_METADATA}" 2>/dev/null || true)"
  if [[ -z "${value}" ]]; then
    local response
    response="$(mktemp)"
    if api_get /api/system/version >"${response}" 2>/dev/null; then
      value="$(json_value updateChannel "${response}")"
    fi
    rm -f "${response}"
  fi
  [[ -n "${value}" ]] || value="${AUTARK_OS_UPDATE_CHANNEL:-beta}"
  case "${value}" in
    stable|beta) printf '%s\n' "${value}" ;;
    preview) printf 'beta\n' ;;
    *) printf 'beta\n' ;;
  esac
}

installed_method() {
  local value=""
  value="$(configured_value AUTARK_OS_INSTALL_METHOD)"
  [[ -n "${value}" ]] || value="$(awk -F= '$1 == "AUTARK_OS_INSTALL_METHOD" {print $2; exit}' "${PUBLIC_INSTALL_METADATA}" 2>/dev/null || true)"
  if [[ -z "${value}" ]] && has_command dpkg-query && dpkg-query -W -f='${Status}' autark-os 2>/dev/null | grep -q 'install ok installed'; then
    value="package"
  fi
  printf '%s\n' "${value:-portable}"
}

host_architecture() {
  local value
  if has_command dpkg; then
    value="$(dpkg --print-architecture)"
  else
    value="$(uname -m)"
  fi
  case "${value}" in
    x86_64|amd64) printf 'amd64\n' ;;
    aarch64|arm64) printf 'arm64\n' ;;
    *) die "Autark-OS updates are not published for this architecture: ${value}" ;;
  esac
}

fetch_update_file() {
  local source="$1"
  local target="$2"
  case "${source}" in
    http://*|https://*)
      has_command curl || die "curl is required to download Autark-OS updates."
      curl --fail --location --silent --show-error \
        --retry 3 --connect-timeout 15 \
        --header "Accept: application/vnd.github+json" \
        --header "X-GitHub-Api-Version: ${UPDATE_API_VERSION}" \
        "${source}" --output "${target}"
      ;;
    file://*)
      cp "${source#file://}" "${target}"
      ;;
    *)
      cp "${source}" "${target}"
      ;;
  esac
}

github_prerelease_tag() {
  local releases_file="$1"
  awk '
    index($0, "    \"tag_name\":") == 1 {
      value = $0
      sub(/^[^:]*:[[:space:]]*\"/, "", value)
      sub(/\"[,]?[[:space:]]*$/, "", value)
      tag = value
    }
    index($0, "    \"draft\": false") == 1 { draft = 0 }
    index($0, "    \"draft\": true") == 1 { draft = 1 }
    index($0, "    \"prerelease\": true") == 1 {
      if (!draft && tag != "") { print tag; exit }
    }
  ' "${releases_file}"
}

default_release_manifest_url() {
  local channel="$1"
  local work_dir="$2"
  local api_file="${work_dir}/github-release.json"
  local tag=""
  if [[ "${channel}" == "stable" ]]; then
    fetch_update_file "https://api.github.com/repos/${UPDATE_REPOSITORY}/releases/latest" "${api_file}"
    tag="$(json_value tag_name "${api_file}")"
  else
    fetch_update_file "https://api.github.com/repos/${UPDATE_REPOSITORY}/releases?per_page=30" "${api_file}"
    tag="$(github_prerelease_tag "${api_file}")"
  fi
  [[ "${tag}" =~ ^v[0-9A-Za-z][0-9A-Za-z._-]*$ ]] || die "No published ${channel} Autark-OS release was found. Draft releases do not become update candidates."
  printf 'https://github.com/%s/releases/download/%s/release-manifest.json\n' "${UPDATE_REPOSITORY}" "${tag}"
}

artifact_manifest_value() {
  local manifest="$1"
  local filename="$2"
  local key="$3"
  awk -v filename="${filename}" -v key="${key}" '
    index($0, "\"fileName\": \"" filename "\"") > 0 { found = 1 }
    found && index($0, "\"" key "\":") > 0 {
      value = $0
      sub("^[^:]*:[[:space:]]*\\\"", "", value)
      sub("\\\"[,]?[[:space:]]*$", "", value)
      print value
      exit
    }
    found && $0 ~ /^[[:space:]]*}[,]?[[:space:]]*$/ { exit }
  ' "${manifest}"
}

safe_extract_tarball() {
  local archive="$1"
  local target_dir="$2"
  if ! tar -tzf "${archive}" | awk '
    /^\// { bad = 1 }
    /(^|\/)\.\.($|\/)/ { bad = 1 }
    /[[:space:]]/ { bad = 1 }
    END { exit bad }
  '; then
    die "The downloaded update contains an unsafe archive path."
  fi
  if ! tar -tvzf "${archive}" | awk '
    function link_escapes_bundle(path, target, directory, count, part_index, depth) {
      if (substr(target, 1, 1) == "/") {
        return 1
      }
      directory = path
      sub("/[^/]*$", "", directory)
      count = split(directory "/" target, parts, "/")
      depth = 0
      for (part_index = 1; part_index <= count; part_index++) {
        if (parts[part_index] == "" || parts[part_index] == ".") {
          continue
        }
        if (parts[part_index] == "..") {
          if (depth == 0) {
            return 1
          }
          depth--
        } else {
          depth++
        }
      }
      return 0
    }
    substr($1, 1, 1) == "h" { bad = 1 }
    substr($1, 1, 1) == "l" {
      arrow = 0
      for (field = 1; field <= NF; field++) {
        if ($field == "->") {
          arrow = field
          break
        }
      }
      if (arrow == 0 || arrow + 1 != NF || link_escapes_bundle($(arrow - 1), $(arrow + 1))) {
        bad = 1
      }
    }
    END { exit bad }
  '; then
    die "The downloaded update contains an unsafe archive link."
  fi
  mkdir -p "${target_dir}"
  tar -xzf "${archive}" -C "${target_dir}"
}

verify_release_bundle() {
  local bundle_dir="$1"
  [[ -d "${bundle_dir}" ]] || die "--release-bundle must be a directory: ${bundle_dir}"
  bundle_dir="$(cd "${bundle_dir}" && pwd -P)"
  local required_file
  for required_file in \
    autark-os-release.json SHA256SUMS \
    backend/autark-os-backend.jar runtime/bin/java \
    scripts/autark-os scripts/autark-os-fileops \
    scripts/bootstrap-autark-os.sh scripts/install-autark-os-service.sh; do
    [[ -r "${bundle_dir}/${required_file}" ]] || die "Release bundle is incomplete: ${bundle_dir}/${required_file}"
  done
  has_command sha256sum || die "sha256sum is required to verify release bundle checksums."

  local verification_dir listed_files actual_files manifest_error
  verification_dir="$(mktemp -d)"
  listed_files="${verification_dir}/listed-files"
  actual_files="${verification_dir}/actual-files"
  manifest_error="${verification_dir}/manifest-error"

  if ! awk '
    function fail(message) {
      print message > error_file
      failed = 1
      exit 1
    }
    NF != 2 { fail("Each checksum line must contain one digest and one relative file path.") }
    {
      digest = $1
      path = $2
      if (substr(path, 1, 1) == "*") {
        path = substr(path, 2)
      }
      if (length(digest) != 64 || digest !~ /^[0-9A-Fa-f]+$/) {
        fail("The checksum manifest contains an invalid SHA-256 digest.")
      }
      if (path == "" || path == "SHA256SUMS" || substr(path, 1, 1) == "/") {
        fail("The checksum manifest contains an unsafe file path.")
      }
      component_count = split(path, components, "/")
      for (component_index = 1; component_index <= component_count; component_index++) {
        if (components[component_index] == "" || components[component_index] == "." || components[component_index] == "..") {
          fail("The checksum manifest contains an unsafe file path.")
        }
      }
      if (seen[path]++) {
        fail("The checksum manifest lists the same file more than once.")
      }
      print path
    }
  ' error_file="${manifest_error}" "${bundle_dir}/SHA256SUMS" | sort >"${listed_files}"; then
    local error_message="The release checksum manifest is malformed."
    [[ ! -s "${manifest_error}" ]] || error_message="$(<"${manifest_error}")"
    rm -rf "${verification_dir}"
    die "${error_message}"
  fi

  local symlink resolved_target
  while IFS= read -r -d '' symlink; do
    resolved_target="$(readlink -f "${symlink}" 2>/dev/null || true)"
    if [[ -z "${resolved_target}" || ! -f "${resolved_target}" || "${resolved_target}" != "${bundle_dir}/"* ]]; then
      rm -rf "${verification_dir}"
      die "Release bundle symlinks must resolve to regular files inside the bundle: ${symlink#"${bundle_dir}/"}"
    fi
  done < <(find "${bundle_dir}" -type l -print0)

  (
    cd "${bundle_dir}"
    find . \( -type f -o -type l \) ! -path ./SHA256SUMS -printf '%P\n' | sort
  ) >"${actual_files}"

  if ! cmp -s "${listed_files}" "${actual_files}"; then
    local differences
    differences="$(comm -3 "${listed_files}" "${actual_files}" | head -10 | tr '\n' ' ')"
    rm -rf "${verification_dir}"
    die "Release bundle checksums do not cover exactly the shipped files. Review: ${differences:-unknown file mismatch}"
  fi

  if ! (cd "${bundle_dir}" && sha256sum -c SHA256SUMS >/dev/null); then
    rm -rf "${verification_dir}"
    die "Release bundle checksum verification failed."
  fi
  rm -rf "${verification_dir}"

  local declared_architecture
  declared_architecture="$(json_value artifactArchitecture "${bundle_dir}/autark-os-release.json")"
  [[ -n "${declared_architecture}" ]] || die "Release bundle does not declare its architecture."
  [[ "${declared_architecture}" == "$(host_architecture)" ]] || die "Release bundle is ${declared_architecture}, but this host is $(host_architecture)."
}

UPDATE_CANDIDATE_VERSION=""
UPDATE_CANDIDATE_CHANNEL=""
UPDATE_CANDIDATE_NOTES=""
UPDATE_CANDIDATE_URL=""
UPDATE_CANDIDATE_SHA=""
UPDATE_CANDIDATE_BUNDLE=""
UPDATE_CANDIDATE_PACKAGE=""

resolve_local_update_candidate() {
  local release_bundle="$1"
  if [[ "$(installed_method)" == "package" ]]; then
    die "This installation is owned by apt. Run 'autark-os update' without --release-bundle so it can select and install the matching .deb package."
  fi
  local bundle_dir
  bundle_dir="$(cd "${release_bundle}" && pwd)"
  verify_release_bundle "${bundle_dir}"
  UPDATE_CANDIDATE_VERSION="$(json_value version "${bundle_dir}/autark-os-release.json")"
  UPDATE_CANDIDATE_CHANNEL="$(json_value channel "${bundle_dir}/autark-os-release.json")"
  UPDATE_CANDIDATE_NOTES="$(json_value releaseNotesUrl "${bundle_dir}/autark-os-release.json")"
  UPDATE_CANDIDATE_URL="file://${bundle_dir}"
  UPDATE_CANDIDATE_SHA="verified-internal-checksums"
  UPDATE_CANDIDATE_BUNDLE="${bundle_dir}"
}

resolve_remote_update_candidate() {
  local metadata_url="$1"
  local channel="$2"
  local work_dir="$3"
  local download_artifact="$4"
  local manifest="${work_dir}/release-manifest.json"
  if [[ -z "${metadata_url}" ]]; then
    metadata_url="$(default_release_manifest_url "${channel}" "${work_dir}")"
  fi
  fetch_update_file "${metadata_url}" "${manifest}"

  UPDATE_CANDIDATE_VERSION="$(json_value version "${manifest}")"
  UPDATE_CANDIDATE_CHANNEL="$(json_value channel "${manifest}")"
  UPDATE_CANDIDATE_NOTES="$(json_value releaseNotesUrl "${manifest}")"
  [[ -n "${UPDATE_CANDIDATE_VERSION}" ]] || die "Update metadata does not declare a version: ${metadata_url}"
  [[ "${UPDATE_CANDIDATE_CHANNEL}" == "${channel}" ]] || die "Update metadata is for ${UPDATE_CANDIDATE_CHANNEL:-an unknown channel}, but this installation follows ${channel}."

  local architecture method filename artifact_type
  architecture="$(host_architecture)"
  method="$(installed_method)"
  if [[ "${method}" == "package" ]]; then
    artifact_type="debian-package"
    filename="autark-os_${UPDATE_CANDIDATE_VERSION}_${architecture}.deb"
  else
    artifact_type="tarball"
    filename="autark-os-${UPDATE_CANDIDATE_VERSION}-${architecture}.tar.gz"
  fi
  UPDATE_CANDIDATE_URL="$(artifact_manifest_value "${manifest}" "${filename}" url)"
  UPDATE_CANDIDATE_SHA="$(artifact_manifest_value "${manifest}" "${filename}" sha256)"
  if [[ -z "${UPDATE_CANDIDATE_URL}" ]]; then
    local legacy_bundle_url legacy_bundle_path
    legacy_bundle_url="$(json_value bundleUrl "${manifest}")"
    legacy_bundle_path="$(file_url_path "${legacy_bundle_url}")"
    if [[ -n "${legacy_bundle_url}" && -d "${legacy_bundle_path}" && "${method}" != "package" ]]; then
      UPDATE_CANDIDATE_URL="${legacy_bundle_url}"
      UPDATE_CANDIDATE_SHA="verified-internal-checksums"
      if [[ "${download_artifact}" -eq 1 ]]; then
        resolve_local_update_candidate "${legacy_bundle_path}"
      fi
      return 0
    fi
  fi
  [[ -n "${UPDATE_CANDIDATE_URL}" && -n "${UPDATE_CANDIDATE_SHA}" ]] || die "Release ${UPDATE_CANDIDATE_VERSION} has no verified ${artifact_type} for ${architecture}."

  [[ "${download_artifact}" -eq 1 ]] || return 0
  local artifact="${work_dir}/${filename}"
  fetch_update_file "${UPDATE_CANDIDATE_URL}" "${artifact}"
  printf '%s  %s\n' "${UPDATE_CANDIDATE_SHA}" "${artifact}" | sha256sum -c - >/dev/null || die "Downloaded update checksum verification failed."
  if [[ "${method}" == "package" ]]; then
    UPDATE_CANDIDATE_PACKAGE="${artifact}"
    return 0
  fi

  local extract_dir="${work_dir}/extracted"
  safe_extract_tarball "${artifact}" "${extract_dir}"
  local bundle_dir
  bundle_dir="$(find "${extract_dir}" -mindepth 1 -maxdepth 1 -type d -print -quit)"
  [[ -n "${bundle_dir}" ]] || die "Downloaded update did not contain an Autark-OS release bundle."
  verify_release_bundle "${bundle_dir}"
  UPDATE_CANDIDATE_BUNDLE="${bundle_dir}"
}

replace_env_value() {
  local file="$1"
  shift
  local tmp_file key pattern
  tmp_file="$(mktemp)"
  pattern="^("
  for key in "$@"; do
    pattern+="${key}|"
  done
  pattern="${pattern%|})="
  if [[ -f "${file}" ]]; then
    grep -v -E "${pattern}" "${file}" >"${tmp_file}" || true
  fi
  cat "${tmp_file}" >"${file}"
  rm -f "${tmp_file}"
}

update_paths() {
  UPDATE_INSTALL_DIR="$(configured_value AUTARK_OS_INSTALL_DIR)"
  UPDATE_RUNTIME_DIR="$(configured_value AUTARK_OS_RUNTIME_ROOT)"
  UPDATE_CONFIG_DIR="$(configured_value AUTARK_OS_CONFIG_DIR)"
  UPDATE_LOG_DIR="$(configured_value AUTARK_OS_LOG_DIR)"
  [[ -n "${UPDATE_INSTALL_DIR}" ]] || UPDATE_INSTALL_DIR="$(public_install_value AUTARK_OS_INSTALL_DIR)"
  [[ -n "${UPDATE_RUNTIME_DIR}" ]] || UPDATE_RUNTIME_DIR="$(public_install_value AUTARK_OS_RUNTIME_ROOT)"
  [[ -n "${UPDATE_CONFIG_DIR}" ]] || UPDATE_CONFIG_DIR="$(public_install_value AUTARK_OS_CONFIG_DIR)"
  [[ -n "${UPDATE_LOG_DIR}" ]] || UPDATE_LOG_DIR="$(public_install_value AUTARK_OS_LOG_DIR)"
  [[ -n "${UPDATE_INSTALL_DIR}" ]] || UPDATE_INSTALL_DIR="/opt/autark-os"
  [[ -n "${UPDATE_RUNTIME_DIR}" ]] || UPDATE_RUNTIME_DIR="/var/lib/autark-os"
  [[ -n "${UPDATE_CONFIG_DIR}" ]] || UPDATE_CONFIG_DIR="$(dirname "${CONFIG_FILE}")"
  [[ -n "${UPDATE_LOG_DIR}" ]] || UPDATE_LOG_DIR="/var/log/autark-os"
}

write_update_state() {
  local status="$1"
  local phase="$2"
  local version="$3"
  local snapshot="$4"
  local message="$5"
  local state_dir="${UPDATE_RUNTIME_DIR}/updates"
  mkdir -p "${state_dir}"
  local tmp_file="${state_dir}/update-state.json.tmp"
  printf '{"schemaVersion":1,"status":' >"${tmp_file}"
  json_string "${status}" >>"${tmp_file}"
  printf ',"phase":' >>"${tmp_file}"
  json_string "${phase}" >>"${tmp_file}"
  printf ',"targetVersion":' >>"${tmp_file}"
  json_string "${version}" >>"${tmp_file}"
  printf ',"snapshot":' >>"${tmp_file}"
  json_string "${snapshot}" >>"${tmp_file}"
  printf ',"message":' >>"${tmp_file}"
  json_string "${message}" >>"${tmp_file}"
  printf ',"updatedAt":' >>"${tmp_file}"
  json_string "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >>"${tmp_file}"
  printf '}\n' >>"${tmp_file}"
  mv "${tmp_file}" "${state_dir}/update-state.json"
  printf '%s status=%s phase=%s target=%s message=%s\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "${status}" "${phase}" "${version}" "${message}" \
    >>"${state_dir}/update.log"
}

acquire_update_lock() {
  mkdir -p "${UPDATE_RUNTIME_DIR}/updates"
  if has_command flock; then
    exec 9>"${UPDATE_RUNTIME_DIR}/updates/update.lock"
    flock -n 9 || die "Another Autark-OS update is already running."
  fi
}

prune_update_snapshots() {
  local keep="${AUTARK_OS_UPDATE_SNAPSHOTS_TO_KEEP:-3}"
  [[ "${keep}" =~ ^[1-9][0-9]*$ ]] || keep=3
  local snapshots=()
  find "${UPDATE_RUNTIME_DIR}/updates" -mindepth 1 -maxdepth 1 -type d -name 'pre-update-*.incomplete' -exec rm -rf {} + 2>/dev/null || true
  mapfile -t snapshots < <(find "${UPDATE_RUNTIME_DIR}/updates" -mindepth 1 -maxdepth 1 -type d -name 'pre-update-*' -print 2>/dev/null | sort -r)
  local index
  for ((index = keep; index < ${#snapshots[@]}; index++)); do
    rm -rf "${snapshots[index]}"
  done
}

create_update_snapshot() {
  local target_version="$1"
  local timestamp snapshot_dir incomplete_dir
  timestamp="$(date -u +%Y%m%dT%H%M%SZ)-$$"
  snapshot_dir="${UPDATE_RUNTIME_DIR}/updates/pre-update-${timestamp}"
  incomplete_dir="${snapshot_dir}.incomplete"
  rm -rf "${incomplete_dir}"
  mkdir -p "${incomplete_dir}"
  [[ ! "${UPDATE_INSTALL_DIR}" = "${UPDATE_RUNTIME_DIR}"* ]] || die "Install directory cannot be stored inside the runtime update snapshot path."

  if has_command systemctl && systemctl is-active --quiet "${SERVICE_NAME}.service"; then
    : >"${incomplete_dir}/service-was-active"
  fi
  if has_command systemctl && systemctl is-enabled --quiet "${SERVICE_NAME}.service" 2>/dev/null; then
    : >"${incomplete_dir}/service-was-enabled"
  fi
  [[ -d "${UPDATE_INSTALL_DIR}" ]] && cp -a "${UPDATE_INSTALL_DIR}" "${incomplete_dir}/install"
  [[ -d "${UPDATE_CONFIG_DIR}" ]] && cp -a "${UPDATE_CONFIG_DIR}" "${incomplete_dir}/config"
  [[ -f "${SERVICE_FILE}" ]] && cp -a "${SERVICE_FILE}" "${incomplete_dir}/service-file"
  [[ -e "${CLI_LINK}" || -L "${CLI_LINK}" ]] && cp -a "${CLI_LINK}" "${incomplete_dir}/cli-link"
  [[ -f "${SUDOERS_FILE}" ]] && cp -a "${SUDOERS_FILE}" "${incomplete_dir}/sudoers-file"
  mkdir -p "${incomplete_dir}/database"
  local database_file
  for database_file in "${UPDATE_RUNTIME_DIR}"/autark-os.db "${UPDATE_RUNTIME_DIR}"/autark-os.db-shm "${UPDATE_RUNTIME_DIR}"/autark-os.db-wal; do
    [[ -f "${database_file}" ]] && cp -a "${database_file}" "${incomplete_dir}/database/"
  done
  printf '%s\n' "${target_version}" >"${incomplete_dir}/target-version"
  mv "${incomplete_dir}" "${snapshot_dir}"
  printf '%s\n' "${snapshot_dir}"
}

recover_interrupted_update() {
  local state_file="${UPDATE_RUNTIME_DIR}/updates/update-state.json"
  [[ -r "${state_file}" ]] || return 0
  local status snapshot target
  status="$(json_value status "${state_file}")"
  snapshot="$(json_value snapshot "${state_file}")"
  target="$(json_value targetVersion "${state_file}")"
  case "${status}" in
    running|rolling_back)
      if [[ -n "${snapshot}" && -d "${snapshot}" ]]; then
        log "An interrupted update was found. Restoring its completed pre-update snapshot before continuing."
        restore_update_snapshot "${snapshot}"
        write_update_state "rolled_back" "interrupted-update" "${target}" "${snapshot}" "Recovered the previous release after an interrupted update."
      else
        log "An interrupted update stopped before program files were replaced; safely starting the update again."
      fi
      ;;
  esac
}

restore_update_snapshot() {
  local snapshot_dir="$1"
  [[ -d "${snapshot_dir}" ]] || die "Update snapshot does not exist: ${snapshot_dir}"
  log "Restoring Autark-OS from ${snapshot_dir}."
  if has_command systemctl; then
    systemctl stop "${SERVICE_NAME}.service" >/dev/null 2>&1 || true
  fi

  rm -rf "${UPDATE_INSTALL_DIR}"
  [[ -d "${snapshot_dir}/install" ]] && cp -a "${snapshot_dir}/install" "${UPDATE_INSTALL_DIR}"
  rm -rf "${UPDATE_CONFIG_DIR}"
  [[ -d "${snapshot_dir}/config" ]] && cp -a "${snapshot_dir}/config" "${UPDATE_CONFIG_DIR}"
  if [[ -f "${snapshot_dir}/service-file" ]]; then
    cp -a "${snapshot_dir}/service-file" "${SERVICE_FILE}"
  else
    rm -f "${SERVICE_FILE}"
  fi
  rm -f "${CLI_LINK}"
  [[ -e "${snapshot_dir}/cli-link" || -L "${snapshot_dir}/cli-link" ]] && cp -a "${snapshot_dir}/cli-link" "${CLI_LINK}"
  if [[ -f "${snapshot_dir}/sudoers-file" ]]; then
    cp -a "${snapshot_dir}/sudoers-file" "${SUDOERS_FILE}"
  else
    rm -f "${SUDOERS_FILE}"
  fi
  rm -f "${UPDATE_RUNTIME_DIR}/autark-os.db" "${UPDATE_RUNTIME_DIR}/autark-os.db-shm" "${UPDATE_RUNTIME_DIR}/autark-os.db-wal"
  if compgen -G "${snapshot_dir}/database/autark-os.db*" >/dev/null; then
    cp -a "${snapshot_dir}"/database/autark-os.db* "${UPDATE_RUNTIME_DIR}/"
  fi

  if has_command systemctl; then
    systemctl daemon-reload
    if [[ -f "${snapshot_dir}/service-was-enabled" ]]; then
      systemctl enable "${SERVICE_NAME}.service" >/dev/null 2>&1 || true
    fi
    if [[ -f "${snapshot_dir}/service-was-active" ]]; then
      systemctl start "${SERVICE_NAME}.service"
    fi
  fi
  ensure_cli_command_access
}

ensure_cli_command_access() {
  local installed_cli="${UPDATE_INSTALL_DIR}/bin/autark-os"
  [[ -d "${UPDATE_INSTALL_DIR}/bin" ]] || return 0
  chmod 0755 "${UPDATE_INSTALL_DIR}/bin"
  [[ -x "${installed_cli}" ]] || return 0
  mkdir -p "$(dirname "${CLI_LINK}")"
  if [[ ! -x "${CLI_LINK}" ]]; then
    rm -f "${CLI_LINK}"
    ln -s "${installed_cli}" "${CLI_LINK}"
    log "Restored the Autark-OS command link at ${CLI_LINK}."
  fi
}

wait_for_update_health() {
  local waited=0
  local base_url="http://127.0.0.1:$(resolve_port)"
  while (( waited < UPDATE_HEALTH_TIMEOUT )); do
    if curl --fail --silent --show-error --max-time 3 "${base_url}/api/health" >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done
  return 1
}

print_update_health_diagnostics() {
  local label="$1"
  local state_dir="${UPDATE_RUNTIME_DIR}/updates"
  local health_url="http://127.0.0.1:$(resolve_port)/api/health"
  mkdir -p "${state_dir}"
  {
    printf '[autark-os] Health diagnostics for %s.\n' "${label}"
    printf '[autark-os] Expected health URL: %s\n' "${health_url}"
    if has_command systemctl; then
      systemctl show "${SERVICE_NAME}.service" \
        --property=ActiveState,SubState,Result,ExecMainCode,ExecMainStatus,NRestarts \
        --no-pager 2>&1 || true
      systemctl status "${SERVICE_NAME}.service" --no-pager --full 2>&1 || true
    fi
    if has_command journalctl; then
      journalctl -u "${SERVICE_NAME}.service" -n 80 --no-pager 2>&1 || true
    fi
    curl --fail --silent --show-error --max-time 3 "${health_url}" 2>&1 || true
    printf '\n'
  } | tee -a "${state_dir}/update.log" >&2
}

write_installed_update_metadata() {
  local release_json="$1"
  local previous_version="$2"
  local previous_sha="$3"
  local previous_date="$4"
  local snapshot_dir="$5"
  local new_version new_sha new_date channel method
  new_version="$(json_value version "${release_json}")"
  new_sha="$(json_value buildSha "${release_json}")"
  new_date="$(json_value buildDate "${release_json}")"
  channel="$(json_value channel "${release_json}")"
  method="$(installed_method)"
  replace_env_value "${CONFIG_FILE}" \
    AUTARK_OS_VERSION AUTARK_OS_BUILD_SHA AUTARK_OS_BUILD_DATE AUTARK_OS_UPDATE_CHANNEL AUTARK_OS_INSTALL_METHOD \
    AUTARK_OS_PREVIOUS_VERSION AUTARK_OS_PREVIOUS_BUILD_SHA AUTARK_OS_PREVIOUS_BUILD_DATE AUTARK_OS_PREVIOUS_BACKEND_JAR AUTARK_OS_PRE_UPDATE_SNAPSHOT_DIR
  cat >>"${CONFIG_FILE}" <<EOF
AUTARK_OS_VERSION=${new_version}
AUTARK_OS_BUILD_SHA=${new_sha}
AUTARK_OS_BUILD_DATE=${new_date}
AUTARK_OS_UPDATE_CHANNEL=${channel}
AUTARK_OS_INSTALL_METHOD=${method}
AUTARK_OS_PREVIOUS_VERSION=${previous_version}
AUTARK_OS_PREVIOUS_BUILD_SHA=${previous_sha}
AUTARK_OS_PREVIOUS_BUILD_DATE=${previous_date}
AUTARK_OS_PREVIOUS_BACKEND_JAR=${snapshot_dir}/install/backend/autark-os-backend.jar
AUTARK_OS_PRE_UPDATE_SNAPSHOT_DIR=${snapshot_dir}
EOF
  chmod 0640 "${CONFIG_FILE}"
  mkdir -p "${UPDATE_INSTALL_DIR}/release-metadata"
  cp "${release_json}" "${UPDATE_INSTALL_DIR}/release-metadata/autark-os-release.json"
  cat >"${UPDATE_INSTALL_DIR}/release-metadata/install.env" <<EOF
AUTARK_OS_VERSION=${new_version}
AUTARK_OS_UPDATE_CHANNEL=${channel}
AUTARK_OS_INSTALL_METHOD=${method}
AUTARK_OS_UPDATE_REPOSITORY=${UPDATE_REPOSITORY}
AUTARK_OS_INSTALL_DIR=${UPDATE_INSTALL_DIR}
AUTARK_OS_RUNTIME_ROOT=${UPDATE_RUNTIME_DIR}
AUTARK_OS_CONFIG_DIR=${UPDATE_CONFIG_DIR}
AUTARK_OS_LOG_DIR=${UPDATE_LOG_DIR}
EOF
  chmod 0644 "${UPDATE_INSTALL_DIR}/release-metadata/autark-os-release.json" "${UPDATE_INSTALL_DIR}/release-metadata/install.env"
}

install_release_bundle() {
  local bundle_dir="$1"
  local skip_service_restart="$2"
  local release_json="${bundle_dir}/autark-os-release.json"
  local setup_script="${bundle_dir}/scripts/install-autark-os-service.sh"
  local version build_sha build_date channel port method
  version="$(json_value version "${release_json}")"
  build_sha="$(json_value buildSha "${release_json}")"
  build_date="$(json_value buildDate "${release_json}")"
  channel="$(json_value channel "${release_json}")"
  port="$(resolve_port)"
  method="$(installed_method)"
  chmod 0755 "${setup_script}" || return 1
  env \
    AUTARK_OS_RUNTIME_DIR="${UPDATE_RUNTIME_DIR}" \
    AUTARK_OS_CONFIG_DIR="${UPDATE_CONFIG_DIR}" \
    AUTARK_OS_LOG_DIR="${UPDATE_LOG_DIR}" \
    AUTARK_OS_INSTALL_DIR="${UPDATE_INSTALL_DIR}" \
    AUTARK_OS_BACKEND_JAR="${bundle_dir}/backend/autark-os-backend.jar" \
    AUTARK_OS_RUNTIME_IMAGE="${bundle_dir}/runtime" \
    AUTARK_OS_JAVA_BIN="${bundle_dir}/runtime/bin/java" \
    AUTARK_OS_SERVER_PORT="${port}" \
    AUTARK_OS_SERVICE_NAME="${SERVICE_NAME}" \
    AUTARK_OS_SERVICE_FILE="${SERVICE_FILE}" \
    AUTARK_OS_CLI_LINK="${CLI_LINK}" \
    AUTARK_OS_SUDOERS_FILE="${SUDOERS_FILE}" \
    AUTARK_OS_VERSION="${version}" \
    AUTARK_OS_BUILD_SHA="${build_sha}" \
    AUTARK_OS_BUILD_DATE="${build_date}" \
    AUTARK_OS_UPDATE_CHANNEL="${channel}" \
    AUTARK_OS_INSTALL_METHOD="${method}" \
    "${setup_script}" --skip-tailscale --no-start || return 1
  [[ "${skip_service_restart}" -eq 0 ]] || return 0
  systemctl enable "${SERVICE_NAME}.service" >/dev/null 2>&1 || true
  systemctl start "${SERVICE_NAME}.service" || return 1
}

install_release_bundle_files_only() {
  local bundle_dir="$1"
  mkdir -p "${UPDATE_INSTALL_DIR}/backend" "${UPDATE_INSTALL_DIR}/bin"
  cp "${bundle_dir}/backend/autark-os-backend.jar" "${UPDATE_INSTALL_DIR}/backend/autark-os-backend.jar" || return 1
  rm -rf "${UPDATE_INSTALL_DIR}/runtime"
  cp -a "${bundle_dir}/runtime" "${UPDATE_INSTALL_DIR}/runtime" || return 1
  local script_name
  for script_name in autark-os autark-os-fileops bootstrap-autark-os.sh install-autark-os-service.sh install-autark-os.sh autark-os-gui-installer.sh supported-host-matrix.env; do
    [[ -f "${bundle_dir}/scripts/${script_name}" ]] || continue
    cp "${bundle_dir}/scripts/${script_name}" "${UPDATE_INSTALL_DIR}/bin/${script_name}" || return 1
    if [[ "${script_name}" == "supported-host-matrix.env" ]]; then
      chmod 0644 "${UPDATE_INSTALL_DIR}/bin/${script_name}"
    else
      chmod 0755 "${UPDATE_INSTALL_DIR}/bin/${script_name}"
    fi
  done
}

apply_release_bundle_update() {
  local release_bundle="$1"
  local skip_service_restart="$2"
  if [[ "$(id -u)" -ne 0 && "${skip_service_restart}" -ne 1 ]]; then
    die "Applying an update requires administrator access. Rerun with sudo or use the unified 'autark-os update' command."
  fi
  update_paths
  acquire_update_lock
  recover_interrupted_update
  verify_release_bundle "${release_bundle}"
  [[ -f "${CONFIG_FILE}" ]] || die "No installed Autark-OS configuration was found at ${CONFIG_FILE}. Use 'autark-os install' for a first installation."

  local release_json="${release_bundle}/autark-os-release.json"
  local target_version previous_version previous_sha previous_date snapshot_dir
  target_version="$(json_value version "${release_json}")"
  previous_version="$(configured_value AUTARK_OS_VERSION)"
  previous_sha="$(configured_value AUTARK_OS_BUILD_SHA)"
  previous_date="$(configured_value AUTARK_OS_BUILD_DATE)"
  local service_was_active=0 service_was_enabled=0
  if has_command systemctl && systemctl is-active --quiet "${SERVICE_NAME}.service"; then
    service_was_active=1
  fi
  if has_command systemctl && systemctl is-enabled --quiet "${SERVICE_NAME}.service" 2>/dev/null; then
    service_was_enabled=1
  fi
  write_update_state "running" "stopping-service" "${target_version}" "" "Preparing the installed service for update."
  if has_command systemctl; then
    systemctl stop "${SERVICE_NAME}.service" >/dev/null 2>&1 || true
  fi
  snapshot_dir="$(create_update_snapshot "${target_version}")"
  [[ -f "${CONFIG_FILE}" ]] && cp -a "${CONFIG_FILE}" "${snapshot_dir}/autark-os.env"
  cp "${release_json}" "${snapshot_dir}/autark-os-release.json"
  [[ "${service_was_active}" -eq 0 ]] || : >"${snapshot_dir}/service-was-active"
  [[ "${service_was_enabled}" -eq 0 ]] || : >"${snapshot_dir}/service-was-enabled"
  write_update_state "running" "installing-release" "${target_version}" "${snapshot_dir}" "Installing verified Autark-OS files."

  local install_failed=0
  if [[ "${skip_service_restart}" -eq 1 ]]; then
    install_release_bundle_files_only "${release_bundle}" || install_failed=1
  else
    install_release_bundle "${release_bundle}" 0 || install_failed=1
  fi
  if [[ "${install_failed}" -eq 1 ]]; then
    write_update_state "rolling_back" "install-failed" "${target_version}" "${snapshot_dir}" "Release installation failed; restoring the previous version."
    restore_update_snapshot "${snapshot_dir}" || true
    write_update_state "rolled_back" "complete" "${target_version}" "${snapshot_dir}" "The update failed and the previous release was restored."
    die "The update could not be installed. Autark-OS restored the previous release."
  fi
  ensure_cli_command_access
  write_installed_update_metadata "${release_json}" "${previous_version}" "${previous_sha}" "${previous_date}" "${snapshot_dir}"

  if [[ "${skip_service_restart}" -eq 1 ]]; then
    write_update_state "completed" "restart-skipped" "${target_version}" "${snapshot_dir}" "Files were updated without restarting the service."
    log "Updated Autark-OS to ${target_version}; service restart was skipped."
    return 0
  fi

  write_update_state "running" "verifying-health" "${target_version}" "${snapshot_dir}" "Waiting for Autark-OS health verification."
  if ! wait_for_update_health; then
    print_update_health_diagnostics "new release ${target_version}"
    write_update_state "rolling_back" "health-failed" "${target_version}" "${snapshot_dir}" "The new release did not become healthy; restoring the previous version."
    restore_update_snapshot "${snapshot_dir}" || true
    if wait_for_update_health; then
      write_update_state "rolled_back" "complete" "${target_version}" "${snapshot_dir}" "The new release failed health verification and the previous release is healthy again."
      die "Autark-OS ${target_version} did not become healthy. The previous release was restored successfully."
    fi
    print_update_health_diagnostics "restored release"
    write_update_state "rollback_failed" "health-failed" "${target_version}" "${snapshot_dir}" "Neither the new release nor the restored release became healthy."
    die "The update failed and the restored release also needs attention. Run 'autark-os logs' and 'autark-os support-bundle'."
  fi
  write_update_state "completed" "complete" "${target_version}" "${snapshot_dir}" "Autark-OS updated successfully and passed health verification."
  prune_update_snapshots
  log "Autark-OS ${target_version} is installed and healthy."
}

apply_package_update() {
  local package_file="$1"
  [[ "$(id -u)" -eq 0 ]] || die "Applying a package update requires administrator access."
  has_command apt-get || die "This package-managed installation requires apt-get for updates."
  local target_version="unknown"
  has_command dpkg-deb && target_version="$(dpkg-deb -f "${package_file}" Version 2>/dev/null || printf 'unknown')"
  update_paths
  acquire_update_lock
  write_update_state "running" "package-install" "${target_version}" "" "Applying the verified Debian package through apt."
  if ! DEBIAN_FRONTEND=noninteractive apt-get install -y "${package_file}"; then
    write_update_state "failed" "package-install" "${target_version}" "" "The package transaction failed. Its maintainer hook attempted to restore the pre-upgrade service snapshot."
    die "The package update failed. Review apt output, 'autark-os update status', and 'autark-os logs'."
  fi
  if ! wait_for_update_health; then
    print_update_health_diagnostics "package release ${target_version}"
    write_update_state "failed" "package-health" "${target_version}" "" "The package transaction completed, but Autark-OS did not become healthy."
    die "The package was installed, but Autark-OS did not become healthy. Run 'autark-os logs'."
  fi
  write_update_state "completed" "complete" "${target_version}" "" "The package-managed Autark-OS update completed and passed health verification."
}

print_update_check() {
  local json_output="$1"
  local force="$2"
  local current update_available=false
  current="$(installed_version)"
  [[ "${force}" -eq 1 || "${current}" != "${UPDATE_CANDIDATE_VERSION}" ]] && update_available=true
  if [[ "${json_output}" -eq 1 ]]; then
    printf '{"schemaVersion":1,"currentVersion":'
    json_string "${current}"
    printf ',"availableVersion":'
    json_string "${UPDATE_CANDIDATE_VERSION}"
    printf ',"updateAvailable":%s,"channel":' "${update_available}"
    json_string "${UPDATE_CANDIDATE_CHANNEL}"
    printf ',"releaseNotesUrl":'
    json_string "${UPDATE_CANDIDATE_NOTES}"
    printf ',"artifactUrl":'
    json_string "${UPDATE_CANDIDATE_URL}"
    printf ',"releaseBundleUrl":'
    json_string "${UPDATE_CANDIDATE_URL}"
    printf ',"artifactSha256":'
    json_string "${UPDATE_CANDIDATE_SHA}"
    printf ',"installMethod":'
    json_string "$(installed_method)"
    printf ',"requiresSourceCheckout":false,"requiresNodeYarnOrGit":false'
    printf '}\n'
    return 0
  fi
  log "Update check"
  print_version_line "Current version" "${current}"
  print_version_line "Available version" "${UPDATE_CANDIDATE_VERSION}"
  print_version_line "Update available" "${update_available}"
  print_version_line "Channel" "${UPDATE_CANDIDATE_CHANNEL}"
  print_version_line "Install method" "$(installed_method)"
  [[ -n "${UPDATE_CANDIDATE_NOTES}" ]] && print_version_line "Release notes" "${UPDATE_CANDIDATE_NOTES}"
}

print_update_plan() {
  local json_output="$1"
  update_paths
  if [[ "${json_output}" -eq 1 ]]; then
    printf '{"schemaVersion":1,"targetVersion":'
    json_string "${UPDATE_CANDIDATE_VERSION}"
    printf ',"channel":'
    json_string "${UPDATE_CANDIDATE_CHANNEL}"
    printf ',"artifactUrl":'
    json_string "${UPDATE_CANDIDATE_URL}"
    printf ',"snapshotRoot":'
    json_string "${UPDATE_RUNTIME_DIR}/updates"
    printf ',"steps":["verify release","stop service","snapshot program, configuration, and database","install release","start service","verify health","rollback automatically on failure"]'
    printf ',"preserves":["managed app data","backups","Tailscale identity","Docker installation"]}\n'
    return 0
  fi
  log "Update plan for Autark-OS ${UPDATE_CANDIDATE_VERSION}"
  log "  1. Verify the architecture-specific release and checksums."
  log "  2. Stop ${SERVICE_NAME}.service and snapshot program files, configuration, and the Autark-OS database."
  log "  3. Install the backend, bundled Java runtime, helper commands, and service configuration."
  log "  4. Start Autark-OS and wait for bounded health verification."
  log "  5. Restore the snapshot automatically if installation or health verification fails."
  log "Managed app data, backups, Docker, and the host Tailscale identity are not replaced by this update."
}

run_update_apply_with_elevation() {
  local release_bundle="$1"
  local package_file="$2"
  local skip_service_restart="$3"
  if [[ "$(id -u)" -eq 0 ]]; then
    if [[ -n "${package_file}" ]]; then
      apply_package_update "${package_file}"
    else
      apply_release_bundle_update "${release_bundle}" "${skip_service_restart}"
    fi
    return
  fi
  if [[ "${skip_service_restart}" -eq 1 && -n "${release_bundle}" ]]; then
    update_paths
    if [[ -w "${UPDATE_INSTALL_DIR}" && -w "${UPDATE_RUNTIME_DIR}" && -w "${CONFIG_FILE}" ]]; then
      apply_release_bundle_update "${release_bundle}" 1
      return
    fi
  fi
  has_command sudo || die "Administrator access is required to apply this update."
  local args=(update apply --yes)
  [[ -n "${release_bundle}" ]] && args+=(--release-bundle "${release_bundle}")
  [[ -n "${package_file}" ]] && args+=(--package-file "${package_file}")
  [[ "${skip_service_restart}" -eq 1 ]] && args+=(--skip-service-restart)
  sudo "${SCRIPT_PATH}" "${args[@]}"
}

update_status() {
  update_paths
  local state_file="${UPDATE_RUNTIME_DIR}/updates/update-state.json"
  if [[ -r "${state_file}" ]]; then
    cat "${state_file}"
    printf '\n'
  elif has_command sudo && sudo test -r "${state_file}" 2>/dev/null; then
    sudo cat "${state_file}"
    printf '\n'
  else
    log "No update run has been recorded yet."
  fi
}

update_rollback() {
  local snapshot_dir="$1"
  [[ "$(id -u)" -eq 0 ]] || {
    has_command sudo || die "Administrator access is required to roll back an update."
    local args=("${SCRIPT_PATH}" update rollback --yes)
    [[ -n "${snapshot_dir}" ]] && args+=(--snapshot "${snapshot_dir}")
    sudo "${args[@]}"
    return
  }
  update_paths
  [[ -n "${snapshot_dir}" ]] || snapshot_dir="$(configured_value AUTARK_OS_PRE_UPDATE_SNAPSHOT_DIR)"
  [[ -n "${snapshot_dir}" ]] || die "No previous update snapshot is recorded."
  acquire_update_lock
  restore_update_snapshot "${snapshot_dir}"
  if [[ -f "${snapshot_dir}/service-was-active" ]] && ! wait_for_update_health; then
    print_update_health_diagnostics "manually restored release"
    die "The snapshot was restored, but Autark-OS did not become healthy. Run 'autark-os logs'."
  fi
  write_update_state "rolled_back" "manual-rollback" "" "${snapshot_dir}" "The recorded pre-update snapshot was restored manually."
  log "Restored the pre-update Autark-OS snapshot."
}

update_command() {
  local action="run"
  case "${1:-}" in
    check|plan|apply|status|rollback)
      action="$1"
      shift
      ;;
  esac

  local json_output=0 metadata_url="${AUTARK_OS_UPDATE_METADATA_URL:-}" release_bundle="" package_file=""
  local channel="$(installed_channel)" yes=0 dry_run=0 skip_service_restart=0 force=0 snapshot_dir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --check) action="check" ;;
      --json) json_output=1 ;;
      --metadata-url)
        shift
        [[ $# -gt 0 ]] || die "--metadata-url requires a URL or path."
        metadata_url="$1"
        ;;
      --metadata-url=*) metadata_url="${1#*=}" ;;
      --release-bundle)
        shift
        [[ $# -gt 0 ]] || die "--release-bundle requires a directory."
        release_bundle="$1"
        ;;
      --release-bundle=*) release_bundle="${1#*=}" ;;
      --package-file)
        shift
        [[ $# -gt 0 ]] || die "--package-file requires a file."
        package_file="$1"
        ;;
      --package-file=*) package_file="${1#*=}" ;;
      --channel)
        shift
        [[ $# -gt 0 ]] || die "--channel requires stable or beta."
        channel="$1"
        ;;
      --channel=*) channel="${1#*=}" ;;
      --yes) yes=1 ;;
      --dry-run) dry_run=1; action="plan" ;;
      --skip-service-restart) skip_service_restart=1 ;;
      --force) force=1 ;;
      --snapshot)
        shift
        [[ $# -gt 0 ]] || die "--snapshot requires a directory."
        snapshot_dir="$1"
        ;;
      --snapshot=*) snapshot_dir="${1#*=}" ;;
      -h|--help)
        cat <<UPDATE_USAGE
Usage: autark-os update [subcommand] [options]

Without a subcommand, runs the complete update chain: check, plan, confirm,
download, verify, apply, health-check, and automatic rollback when needed.

Subcommands:
  check       Check the configured channel for a published update.
  plan        Show every host mutation and preservation boundary.
  apply       Download/verify and apply the selected update.
  status      Print the durable state from the most recent update run.
  rollback    Restore the most recent pre-update snapshot.

Options:
  --channel stable|beta   Override the installed update channel.
  --metadata-url URL      Use a release-manifest.json URL or local file.
  --release-bundle DIR    Use an extracted architecture-specific release bundle.
  --yes                   Confirm non-interactively.
  --dry-run               Alias for the plan subcommand.
  --force                 Reapply a release with the installed version number.
  --json                  Machine-readable check or plan output.
  --skip-service-restart  Advanced: replace files without starting/validating the service.
  --snapshot DIR          Snapshot to restore with rollback.
  -h, --help              Show this help.

Compatibility:
  autark-os update --check continues to behave like 'autark-os update check'.
UPDATE_USAGE
        return 0
        ;;
      *) die "Unknown update option: $1" ;;
    esac
    shift
  done
  case "${channel}" in stable|beta) ;; *) die "--channel must be stable or beta: ${channel}" ;; esac

  if [[ "${action}" == "status" ]]; then
    update_status
    return
  fi
  if [[ "${action}" == "rollback" ]]; then
    [[ "${yes}" -eq 1 ]] || confirm_default_no "Restore the previous Autark-OS snapshot?" || { log "Rollback cancelled."; return 1; }
    update_rollback "${snapshot_dir}"
    return
  fi
  if [[ "${action}" == "apply" && -n "${package_file}" ]]; then
    run_update_apply_with_elevation "" "${package_file}" "${skip_service_restart}"
    return
  fi
  if [[ "${action}" == "apply" && -n "${release_bundle}" ]]; then
    resolve_local_update_candidate "${release_bundle}"
    [[ "${yes}" -eq 1 ]] || confirm_default_no "Apply Autark-OS ${UPDATE_CANDIDATE_VERSION}?" || { log "Update cancelled."; return 1; }
    run_update_apply_with_elevation "${UPDATE_CANDIDATE_BUNDLE}" "" "${skip_service_restart}"
    return
  fi

  local work_dir
  work_dir="$(mktemp -d)"
  trap 'rm -rf "${work_dir}"' RETURN
  if [[ -n "${release_bundle}" ]]; then
    resolve_local_update_candidate "${release_bundle}"
  else
    resolve_remote_update_candidate "${metadata_url}" "${channel}" "${work_dir}" 0
  fi

  if [[ "${action}" == "check" ]]; then
    print_update_check "${json_output}" "${force}"
    return
  fi
  if [[ "${action}" == "plan" ]]; then
    print_update_plan "${json_output}"
    return
  fi

  print_update_check 0 "${force}"
  if [[ "${force}" -eq 0 && "$(installed_version)" == "${UPDATE_CANDIDATE_VERSION}" ]]; then
    log "Autark-OS is already current. Use --force only when intentionally repairing this release."
    return 0
  fi
  print_update_plan 0
  if [[ "${yes}" -ne 1 ]] && ! confirm_default_no "Download and install Autark-OS ${UPDATE_CANDIDATE_VERSION}?"; then
    log "Update cancelled."
    return 1
  fi

  if [[ -z "${release_bundle}" ]]; then
    resolve_remote_update_candidate "${metadata_url}" "${channel}" "${work_dir}" 1
  fi
  run_update_apply_with_elevation "${UPDATE_CANDIDATE_BUNDLE}" "${UPDATE_CANDIDATE_PACKAGE}" "${skip_service_restart}"
  trap - RETURN
  rm -rf "${work_dir}"
}

redact_stream() {
  sed -E \
    -e 's/([A-Za-z0-9_]*(TOKEN|Token|token|PASSWORD|Password|password|SECRET|Secret|secret|SESSION|Session|session|COOKIE|Cookie|cookie|SETUP_CODE|setupCode|setup_code|AUTH_KEY|auth_key|API_KEY|api_key|CREDENTIAL|credential|PRIVATE_KEY|private_key)[A-Za-z0-9_]*[[:space:]]*[=:][[:space:]]*)[^[:space:]",}]+/\1[redacted]/g' \
    -e 's/(Cookie:[[:space:]]*).*/\1[redacted]/g' \
    -e 's/(Authorization:[[:space:]]*Bearer[[:space:]]+)[^[:space:]]+/\1[redacted]/g' \
    -e 's/(Bearer[[:space:]]+)[A-Za-z0-9._~+\/=-]+/\1[redacted]/g' \
    -e 's/("([^"]*(token|password|secret|session|cookie|setupCode|setup_code|authKey|auth_key|apiKey|api_key|credential|privateKey|private_key)[^"]*)"[[:space:]]*:[[:space:]]*")[^"]*(")/\1[redacted]\4/g' \
    -e 's/[A-Za-z0-9.-]+\.ts\.net\.?/[redacted-tailnet-host]/g' \
    -e 's/100\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\.[0-9]{1,3}\.[0-9]{1,3}/[redacted-tailnet-ip]/g' \
    -e 's#https?://(localhost|127\.[0-9.]+|10\.[0-9.]+|192\.168\.[0-9.]+|172\.(1[6-9]|2[0-9]|3[01])\.[0-9.]+|[A-Za-z0-9-]+\.local)(:[0-9]+)?(/[^[:space:]"]*)?#[redacted-private-url]#g' \
    -e 's#(10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}|192\.168\.[0-9]{1,3}\.[0-9]{1,3}|172\.(1[6-9]|2[0-9]|3[01])\.[0-9]{1,3}\.[0-9]{1,3}|127\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3})#[redacted-lan-ip]#g' \
    -e 's#/(home|Users)/[^/[:space:]"]+#[redacted-home-path]#g' \
    -e 's/[A-Za-z0-9.!#$%&*+?^_`{|}~-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}/[redacted-email]/g' \
    -e 's/((host(name)?|device[_-]?name|login[_-]?name|user[_-]?name)[[:space:]]*[=:][[:space:]]*)[^[:space:],;"]+/\1[redacted-host]/Ig'
}

redact_file_to() {
  local source="$1"
  local target="$2"
  if [[ -r "${source}" ]]; then
    redact_stream <"${source}" >"${target}"
  else
    printf 'Unavailable: %s\n' "${source}" >"${target}"
  fi
}

write_json_unavailable() {
  local target="$1"
  local source="$2"
  local message="$3"
  printf '{"schemaVersion":1,"status":"unavailable","source":' >"${target}"
  json_string "${source}" >>"${target}"
  printf ',"message":' >>"${target}"
  json_string "${message}" >>"${target}"
  printf '}\n' >>"${target}"
}

support_bundle_run_bootstrap_json() {
  local mode="$1"
  local target="$2"
  local release_bundle="$3"
  local state_dir="$4"
  local installer
  if ! installer="$(bootstrap_installer)"; then
    write_json_unavailable "${target}" "bootstrap-autark-os.sh ${mode} --json" "bootstrap installer was not found next to this command"
    return 0
  fi

  local args=("${mode}" "--json")
  [[ -n "${release_bundle}" ]] && args+=(--release-bundle "${release_bundle}")
  [[ -n "${state_dir}" ]] && args+=(--state-dir "${state_dir}")
  if "${installer}" "${args[@]}" >"${target}.raw" 2>"${target}.err"; then
    redact_file_to "${target}.raw" "${target}"
  else
    write_json_unavailable "${target}" "${installer} ${mode} --json" "$(head -n 5 "${target}.err" | tr '\n' ' ')"
  fi
  rm -f "${target}.raw" "${target}.err"
}

support_bundle_run_autark_os_doctor() {
  local target="$1"
  if "$0" doctor --json >"${target}.raw" 2>"${target}.err"; then
    redact_file_to "${target}.raw" "${target}"
  else
    write_json_unavailable "${target}" "autark-os doctor --json" "$(head -n 5 "${target}.err" | tr '\n' ' ')"
  fi
  rm -f "${target}.raw" "${target}.err"
}

support_bundle_api_capture() {
  local path="$1"
  local target="$2"
  if (api_get "${path}") >"${target}.raw" 2>"${target}.err"; then
    redact_file_to "${target}.raw" "${target}"
  else
    write_json_unavailable "${target}" "GET ${path}" "The local Autark-OS API did not return this diagnostic."
  fi
  rm -f "${target}.raw" "${target}.err"
}

write_docker_inventory() {
  local target="$1"
  if ! has_command docker; then
    printf 'Docker command unavailable.\n' >"${target}"
    return 0
  fi
  local ids=()
  mapfile -t ids < <(docker ps -a --format '{{.ID}}' 2>/dev/null || true)
  {
    printf 'Autark-OS Docker inventory (credentials and container environment are intentionally excluded)\n'
    docker ps -a --format 'id={{.ID}} name={{.Names}} image={{.Image}} status={{.Status}} compose_project={{.Label "com.docker.compose.project"}} compose_service={{.Label "com.docker.compose.service"}} app_id={{.Label "autark-os.app-id"}} app_instance={{.Label "autark-os.app-instance-id"}} owner_instance={{.Label "autark-os.instance-id"}} config_files={{.Label "com.docker.compose.project.config_files"}}' 2>/dev/null || printf 'Docker inventory could not be read.\n'
    local container_id
    for container_id in "${ids[@]}"; do
      [[ "${container_id}" =~ ^[a-fA-F0-9]{12,64}$ ]] || continue
      printf '\ncontainer=%s mounts:\n' "${container_id}"
      docker inspect --format '{{range .Mounts}}type={{.Type}} destination={{.Destination}}{{println}}{{else}}none{{println}}{{end}}' "${container_id}" 2>/dev/null || printf 'mount inspection unavailable\n'
    done
  } | redact_stream >"${target}"
}

write_disk_summary() {
  local target="$1"
  {
    printf 'Autark-OS relevant disk summary\n'
    printf 'Config file: %s\n' "${CONFIG_FILE}"
    printf 'Install path: %s\n' "$(configured_value AUTARK_OS_INSTALL_DIR)"
    printf 'Runtime path: %s\n' "$(configured_value AUTARK_OS_RUNTIME_ROOT)"
    printf 'Log path: %s\n' "$(configured_value AUTARK_OS_LOG_DIR)"
    if has_command df; then
      df -h "$(configured_value AUTARK_OS_RUNTIME_ROOT 2>/dev/null || printf /)" 2>/dev/null || df -h / 2>/dev/null || true
    else
      printf 'df unavailable\n'
    fi
  } | redact_stream >"${target}"
}

write_dependency_states() {
  local plan_file="$1"
  local target="$2"
  if has_command python3; then
    python3 - "${plan_file}" >"${target}" <<'PY'
import json
import sys

try:
    plan = json.load(open(sys.argv[1]))
except Exception as exc:
    print(json.dumps({"schemaVersion": 1, "status": "unavailable", "message": str(exc)}))
    raise SystemExit(0)

dependencies = plan.get("dependencies", [])
print(json.dumps({"schemaVersion": 1, "source": "install-plan.json", "dependencies": dependencies}, separators=(",", ":")))
PY
  else
    printf '{"schemaVersion":1,"source":"install-plan.json","message":"python3 unavailable; inspect install-plan.json dependencies"}\n' >"${target}"
  fi
}

write_selected_options() {
  local state_dir="$1"
  local target="$2"
  local state_file="${state_dir}/installer-state.json"
  if [[ -n "${state_dir}" && -r "${state_file}" && "$(has_command python3 && printf yes || true)" == "yes" ]]; then
    python3 - "${state_file}" >"${target}.raw" <<'PY'
import json
import sys

state = json.load(open(sys.argv[1]))
selected = state.get("selectedOptions") or {
    "runtimeDir": state.get("runtimeDir") or state.get("selectedRuntimeDir") or "",
    "installDir": state.get("installDir") or "",
    "configDir": state.get("configDir") or "",
    "logDir": state.get("logDir") or "",
    "port": state.get("port") or "",
    "status": state.get("status") or "",
    "lastCompletedStage": state.get("lastCompletedStage") or "",
}
print(json.dumps(selected, separators=(",", ":")))
PY
    redact_file_to "${target}.raw" "${target}"
    rm -f "${target}.raw"
    return 0
  fi

  printf '{'
  printf '"schemaVersion":1'
  printf ',"runtimeDir":'
  json_string "$(configured_value AUTARK_OS_RUNTIME_ROOT)"
  printf ',"installDir":'
  json_string "$(configured_value AUTARK_OS_INSTALL_DIR)"
  printf ',"configDir":'
  json_string "$(configured_value AUTARK_OS_CONFIG_DIR)"
  printf ',"logDir":'
  json_string "$(configured_value AUTARK_OS_LOG_DIR)"
  printf ',"port":'
  json_string "$(resolve_port)"
  printf '}\n'
}

write_service_status() {
  local target="$1"
  if has_command systemctl; then
    {
      systemctl is-active "${SERVICE_NAME}.service" 2>/dev/null || true
      systemctl status "${SERVICE_NAME}.service" --no-pager 2>/dev/null || true
    } | redact_stream >"${target}"
  else
    printf 'systemctl unavailable\n' >"${target}"
  fi
}

write_support_manifest() {
  local target="$1"
  local bundle_name="$2"
  shift 2
  local files=("$@")
  {
    printf '{'
    printf '"schemaVersion":1'
    printf ',"bundleType":"installer-support"'
    printf ',"generatedAt":'
    json_string "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf ',"bundleName":'
    json_string "${bundle_name}"
    printf ',"serviceName":'
    json_string "${SERVICE_NAME}.service"
    printf ',"redacted":true'
    printf ',"supportConsoleCompatible":true'
    printf ',"files":'
    json_string_array "${files[@]}"
    printf '}\n'
  } >"${target}"
}

support_bundle_command() {
  local output=""
  local release_bundle=""
  local state_dir=""
  local installer_log=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --output)
        shift
        [[ $# -gt 0 ]] || die "--output requires a file path."
        output="$1"
        ;;
      --output=*)
        output="${1#*=}"
        ;;
      --release-bundle)
        shift
        [[ $# -gt 0 ]] || die "--release-bundle requires a directory."
        release_bundle="$1"
        ;;
      --release-bundle=*)
        release_bundle="${1#*=}"
        ;;
      --state-dir)
        shift
        [[ $# -gt 0 ]] || die "--state-dir requires a directory."
        state_dir="$1"
        ;;
      --state-dir=*)
        state_dir="${1#*=}"
        ;;
      --installer-log)
        shift
        [[ $# -gt 0 ]] || die "--installer-log requires a file path."
        installer_log="$1"
        ;;
      --installer-log=*)
        installer_log="${1#*=}"
        ;;
      -h|--help)
        cat <<SUPPORT_USAGE
Usage: autark-os support-bundle [options]

Export a redacted installer/setup support archive. The command is safe to run
after failed or successful installs and does not change the host.

Options:
  --output FILE          Write the .tar.gz archive to FILE.
  --release-bundle DIR  Include release metadata and run installer plan checks for DIR.
  --state-dir DIR       Include redacted installer state and selected options.
  --installer-log FILE  Include a redacted installer stage log.
  -h, --help            Show this help.
SUPPORT_USAGE
        return 0
        ;;
      *)
        log "Unknown support-bundle option: $1"
        return 1
        ;;
    esac
    shift
  done

  has_command tar || die "tar is required to write a support bundle archive."
  local timestamp tmp_dir bundle_name bundle_dir archive_output
  timestamp="$(date -u +%Y%m%d%H%M%S)"
  bundle_name="autark-os-installer-support-${timestamp}"
  tmp_dir="$(mktemp -d)"
  bundle_dir="${tmp_dir}/${bundle_name}"
  archive_output="${output:-$(pwd)/${bundle_name}.tar.gz}"
  mkdir -p "${bundle_dir}" "$(dirname "${archive_output}")"

  local files=(
    install-plan.json
    pre-install-doctor.json
    post-install-doctor.json
    os-release.txt
    architecture.txt
    disk-summary.txt
    dependency-states.json
    service-status.txt
    selected-options.json
    config-redacted.env
    installer-stage.log
    release-metadata.json
    update-state.json
    update.log
    application-state.json
    jobs.json
    recent-activity.json
    observed-services.json
    docker-inventory.txt
  )

  support_bundle_run_bootstrap_json --plan "${bundle_dir}/install-plan.json" "${release_bundle}" ""
  support_bundle_run_bootstrap_json --doctor "${bundle_dir}/pre-install-doctor.json" "${release_bundle}" ""
  support_bundle_run_autark_os_doctor "${bundle_dir}/post-install-doctor.json"
  if [[ -r /etc/os-release ]]; then
    redact_file_to /etc/os-release "${bundle_dir}/os-release.txt"
  else
    printf 'os-release unavailable\n' >"${bundle_dir}/os-release.txt"
  fi
  uname -m >"${bundle_dir}/architecture.txt" 2>/dev/null || printf 'unknown\n' >"${bundle_dir}/architecture.txt"
  write_disk_summary "${bundle_dir}/disk-summary.txt"
  write_dependency_states "${bundle_dir}/install-plan.json" "${bundle_dir}/dependency-states.json"
  write_service_status "${bundle_dir}/service-status.txt"
  support_bundle_api_capture "/api/application-state" "${bundle_dir}/application-state.json"
  support_bundle_api_capture "/api/jobs" "${bundle_dir}/jobs.json"
  support_bundle_api_capture "/api/system/support/logs?limit=120" "${bundle_dir}/recent-activity.json"
  support_bundle_api_capture "/api/observed-services" "${bundle_dir}/observed-services.json"
  write_docker_inventory "${bundle_dir}/docker-inventory.txt"
  write_selected_options "${state_dir}" "${bundle_dir}/selected-options.json"
  redact_file_to "${CONFIG_FILE}" "${bundle_dir}/config-redacted.env"
  local installed_runtime_dir
  installed_runtime_dir="$(configured_value AUTARK_OS_RUNTIME_ROOT)"
  [[ -n "${installed_runtime_dir}" ]] || installed_runtime_dir="/var/lib/autark-os"
  redact_file_to "${installed_runtime_dir}/updates/update-state.json" "${bundle_dir}/update-state.json"
  redact_file_to "${installed_runtime_dir}/updates/update.log" "${bundle_dir}/update.log"
  if [[ -n "${installer_log}" ]]; then
    redact_file_to "${installer_log}" "${bundle_dir}/installer-stage.log"
  elif [[ -n "$(configured_value AUTARK_OS_LOG_DIR)" && -r "$(configured_value AUTARK_OS_LOG_DIR)/installer.log" ]]; then
    redact_file_to "$(configured_value AUTARK_OS_LOG_DIR)/installer.log" "${bundle_dir}/installer-stage.log"
  else
    printf 'No installer stage log was available.\n' >"${bundle_dir}/installer-stage.log"
  fi
  if [[ -n "${release_bundle}" && -r "${release_bundle}/autark-os-release.json" ]]; then
    redact_file_to "${release_bundle}/autark-os-release.json" "${bundle_dir}/release-metadata.json"
  else
    printf '{"schemaVersion":1,"version":' >"${bundle_dir}/release-metadata.json"
    json_string "$(configured_value AUTARK_OS_VERSION)" >>"${bundle_dir}/release-metadata.json"
    printf ',"buildSha":' >>"${bundle_dir}/release-metadata.json"
    json_string "$(configured_value AUTARK_OS_BUILD_SHA)" >>"${bundle_dir}/release-metadata.json"
    printf '}\n' >>"${bundle_dir}/release-metadata.json"
  fi
  write_support_manifest "${bundle_dir}/manifest.json" "${bundle_name}" "${files[@]}"

  tar -czf "${archive_output}" -C "${tmp_dir}" "${bundle_name}"
  rm -rf "${tmp_dir}"
  log "Support bundle written: ${archive_output}"
}

remove_managed_apps_before_data_deletion() {
  local apps_file
  apps_file="$(mktemp)"
  if ! api_get /api/apps >"${apps_file}" 2>/dev/null; then
    rm -f "${apps_file}"
    die "Autark-OS could not safely remove managed containers before deleting data. Start or repair the service, remove each app from My Apps, and retry."
  fi
  local app_ids=()
  mapfile -t app_ids < <(grep -oE '"appId"[[:space:]]*:[[:space:]]*"[^"]+"' "${apps_file}" | sed -E 's/^[^:]+:[[:space:]]*"([^"]+)"$/\1/' | sort -u)
  rm -f "${apps_file}"
  local app_id
  for app_id in "${app_ids[@]}"; do
    [[ "${app_id}" =~ ^[A-Za-z0-9._-]+$ ]] || die "Refusing an unsafe managed app identifier during uninstall: ${app_id}"
    log "Removing managed app containers and private link for ${app_id}; app data remains until the final confirmed deletion step."
    api_delete "/api/apps/${app_id}" >/dev/null || die "Could not safely remove ${app_id}. Review My Apps and retry the uninstall."
  done
}

uninstall_command() {
  local plan_only=0
  local json_output=0
  local dry_run=0
  local yes=0
  local remove_config=0
  local remove_logs=0
  local remove_data=0
  local typed_confirmation=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan)
        plan_only=1
        ;;
      --json)
        json_output=1
        ;;
      --dry-run)
        dry_run=1
        ;;
      --yes)
        yes=1
        ;;
      --remove-config)
        remove_config=1
        ;;
      --remove-logs)
        remove_logs=1
        ;;
      --remove-data)
        remove_data=1
        remove_config=1
        remove_logs=1
        ;;
      --confirm-delete-data)
        shift
        [[ $# -gt 0 ]] || die "--confirm-delete-data requires DELETE-AUTARK-OS-DATA."
        typed_confirmation="$1"
        ;;
      --confirm-delete-data=*)
        typed_confirmation="${1#*=}"
        ;;
      -h|--help)
        cat <<UNINSTALL_USAGE
Usage: autark-os uninstall [options]

Safely remove Autark-OS service and binaries. Runtime data is preserved by
default.

Options:
  --plan                 Print what would be removed and preserved.
  --json                 With --plan, print machine-readable JSON.
  --dry-run              Print removal actions without changing the host.
  --yes                  Run non-interactively.
  --remove-config        Also remove Autark-OS config.
  --remove-logs          Also remove Autark-OS logs.
  --remove-data          Also remove runtime data, apps, backups, and database.
  --confirm-delete-data DELETE-AUTARK-OS-DATA
                         Required with --remove-data.
  -h, --help             Show this help.
UNINSTALL_USAGE
        return 0
        ;;
      *)
        log "Unknown uninstall option: $1"
        return 1
        ;;
    esac
    shift
  done

  if [[ "${remove_data}" -eq 1 && "${typed_confirmation}" != "DELETE-AUTARK-OS-DATA" ]]; then
    log "Destructive uninstall requires: --confirm-delete-data DELETE-AUTARK-OS-DATA"
    return 1
  fi

  local install_dir runtime_dir config_dir log_dir mode
  install_dir="$(configured_value AUTARK_OS_INSTALL_DIR)"
  runtime_dir="$(configured_value AUTARK_OS_RUNTIME_ROOT)"
  config_dir="$(configured_value AUTARK_OS_CONFIG_DIR)"
  log_dir="$(configured_value AUTARK_OS_LOG_DIR)"
  [[ -n "${install_dir}" ]] || install_dir="$(public_install_value AUTARK_OS_INSTALL_DIR)"
  [[ -n "${runtime_dir}" ]] || runtime_dir="$(public_install_value AUTARK_OS_RUNTIME_ROOT)"
  [[ -n "${config_dir}" ]] || config_dir="$(public_install_value AUTARK_OS_CONFIG_DIR)"
  [[ -n "${log_dir}" ]] || log_dir="$(public_install_value AUTARK_OS_LOG_DIR)"
  [[ -n "${install_dir}" ]] || install_dir="/opt/autark-os"
  [[ -n "${runtime_dir}" ]] || runtime_dir="/var/lib/autark-os"
  [[ -n "${config_dir}" ]] || config_dir="$(dirname "${CONFIG_FILE}")"
  [[ -n "${log_dir}" ]] || log_dir="/var/log/autark-os"

  mode="preserve-runtime-data"
  [[ "${remove_config}" -eq 1 || "${remove_logs}" -eq 1 ]] && mode="remove-config-and-logs"
  [[ "${remove_data}" -eq 1 ]] && mode="remove-all-data"

  local remove_paths=("${SERVICE_FILE}" "${CLI_LINK}" "${SUDOERS_FILE}" "${install_dir}")
  local preserve_paths=()
  if [[ "${remove_config}" -eq 1 ]]; then
    remove_paths+=("${config_dir}")
  else
    preserve_paths+=("${config_dir}")
  fi
  if [[ "${remove_logs}" -eq 1 ]]; then
    remove_paths+=("${log_dir}")
  else
    preserve_paths+=("${log_dir}")
  fi
  if [[ "${remove_data}" -eq 1 ]]; then
    remove_paths+=("${runtime_dir}")
  else
    preserve_paths+=("${runtime_dir}")
  fi

  local app_count=0
  if [[ -d "${runtime_dir}/apps" ]]; then
    app_count="$(find "${runtime_dir}/apps" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')"
  fi

  if [[ "${plan_only}" -eq 1 && "${json_output}" -eq 1 ]]; then
    printf '{'
    printf '"schemaVersion":1'
    printf ',"mode":'
    json_string "${mode}"
    printf ',"serviceName":'
    json_string "${SERVICE_NAME}.service"
    printf ',"requiresTypedConfirmation":%s' "$([[ "${remove_data}" -eq 1 ]] && printf true || printf false)"
    printf ',"typedConfirmation":'
    json_string "${typed_confirmation}"
    printf ',"removePaths":'
    json_string_array "${remove_paths[@]}"
    printf ',"preservePaths":'
    json_string_array "${preserve_paths[@]}"
    printf ',"dockerResources":{"installedAppsDetected":%s,"appCount":%s,"warning":' "$([[ "${app_count}" != "0" ]] && printf true || printf false)" "${app_count}"
    if [[ "${remove_data}" -eq 1 ]]; then
      json_string "Managed app containers and private links will be removed before data deletion. Docker volumes outside the Autark-OS runtime folder are preserved for manual review."
    else
      json_string "Managed app containers and Docker volumes are preserved with app data."
    fi
    printf '}'
    printf ',"supportReport":{"offeredBeforeRemoval":true,"command":"autark-os doctor --json"}'
    printf ',"actions":['
    printf '{"id":"offer-support-report","label":"Offer support report before removal","mutatesHost":false},'
    printf '{"id":"stop-service","label":"Stop Autark-OS service","mutatesHost":true},'
    printf '{"id":"remove-binaries","label":"Remove Autark-OS binaries","mutatesHost":true}'
    if [[ "${remove_config}" -eq 1 ]]; then
      printf ',{"id":"remove-config","label":"Remove Autark-OS config","mutatesHost":true}'
    fi
    if [[ "${remove_logs}" -eq 1 ]]; then
      printf ',{"id":"remove-logs","label":"Remove Autark-OS logs","mutatesHost":true}'
    fi
    if [[ "${remove_data}" -eq 1 ]]; then
      printf ',{"id":"remove-managed-apps","label":"Remove managed app containers and private links","mutatesHost":true}'
      printf ',{"id":"remove-runtime-data","label":"Remove runtime data, apps, backups, and database","mutatesHost":true}'
    fi
    printf ']'
    printf '}\n'
    return 0
  fi

  if [[ "${plan_only}" -eq 1 ]]; then
    log "Uninstall mode: ${mode}"
    log "Service to stop: ${SERVICE_NAME}.service"
    for path in "${remove_paths[@]}"; do
      log "Would remove: ${path}"
    done
    for path in "${preserve_paths[@]}"; do
      log "Would preserve: ${path}"
    done
    log "Support report offered before removal: autark-os doctor --json"
    if [[ "${app_count}" != "0" && "${remove_data}" -eq 1 ]]; then
      log "Managed app folders detected: ${app_count}. Managed containers and private links will be removed before data deletion; external Docker volumes are preserved."
    elif [[ "${app_count}" != "0" ]]; then
      log "Managed app folders detected: ${app_count}. Their containers and Docker volumes will be preserved."
    fi
    return 0
  fi

  if [[ "${dry_run}" -eq 1 ]]; then
    log "Would stop service: ${SERVICE_NAME}.service"
    for path in "${remove_paths[@]}"; do
      log "Would remove: ${path}"
    done
    for path in "${preserve_paths[@]}"; do
      log "Would preserve: ${path}"
    done
    log "Would offer support report before removal: autark-os doctor --json"
    return 0
  fi

  if [[ "${yes}" -ne 1 ]]; then
    local confirmed=0
    if [[ "${remove_data}" -eq 1 ]]; then
      confirm_default_no "Permanently remove Autark-OS, managed app containers, runtime data, and backups?" && confirmed=1
    else
      confirm_default_yes "Remove Autark-OS service and binaries while preserving runtime data?" && confirmed=1
    fi
    if [[ "${confirmed}" -ne 1 ]]; then
      log "Uninstall cancelled."
      return 1
    fi
  fi

  if [[ "$(id -u)" -ne 0 ]]; then
    has_command sudo || die "Administrator access is required to uninstall Autark-OS."
    local elevated_args=(uninstall --yes)
    [[ "${remove_config}" -eq 0 ]] || elevated_args+=(--remove-config)
    [[ "${remove_logs}" -eq 0 ]] || elevated_args+=(--remove-logs)
    if [[ "${remove_data}" -eq 1 ]]; then
      elevated_args+=(--remove-data --confirm-delete-data DELETE-AUTARK-OS-DATA)
    fi
    sudo "${SCRIPT_PATH}" "${elevated_args[@]}"
    return
  fi

  if [[ "${remove_data}" -eq 1 ]]; then
    remove_managed_apps_before_data_deletion
  fi

  log "Stopping ${SERVICE_NAME}.service if present."
  if has_command systemctl; then
    systemctl disable --now "${SERVICE_NAME}.service" >/dev/null 2>&1 || true
  fi
  local method
  method="$(installed_method)"
  if [[ "${method}" == "package" ]] && has_command dpkg-query && dpkg-query -W -f='${Status}' autark-os 2>/dev/null | grep -q 'install ok installed'; then
    log "Removing the package-owned Autark-OS release through apt."
    DEBIAN_FRONTEND=noninteractive apt-get remove -y autark-os
  fi
  for path in "${remove_paths[@]}"; do
    [[ -n "${path}" && "${path}" != "/" ]] || die "Refusing to remove unsafe path: ${path}"
    log "Removing ${path}"
    rm -rf "${path}"
  done
  for path in "${preserve_paths[@]}"; do
    log "Preserved ${path}"
  done
  if has_command systemctl; then
    systemctl daemon-reload
  fi
  if [[ "${remove_data}" -eq 1 ]]; then
    if has_command tailscale; then
      tailscale set --operator=root >/dev/null 2>&1 || log "Tailscale is preserved, but its operator setting could not be returned to root."
    fi
    if has_command userdel && id autarkos >/dev/null 2>&1; then
      userdel autarkos >/dev/null 2>&1 || log "The autarkos service user is still in use and was preserved."
    fi
    if has_command groupdel && getent group autarkos >/dev/null 2>&1; then
      groupdel autarkos >/dev/null 2>&1 || log "The autarkos service group is still in use and was preserved."
    fi
  fi
}

print_where_line() {
  local label="$1"
  local value="$2"
  printf '%-18s %s\n' "${label}:" "${value:-unknown}"
}

where_info() {
  local install_path runtime_path
  install_path="$(configured_value AUTARK_OS_INSTALL_DIR)"
  runtime_path="$(configured_value AUTARK_OS_RUNTIME_ROOT)"
  [[ -n "${install_path}" ]] || install_path="$(public_install_value AUTARK_OS_INSTALL_DIR)"
  [[ -n "${runtime_path}" ]] || runtime_path="$(public_install_value AUTARK_OS_RUNTIME_ROOT)"
  print_where_line "Config file" "${CONFIG_FILE}"
  print_where_line "Service" "${SERVICE_NAME}.service"
  print_where_line "Port" "$(resolve_port)"
  print_where_line "URL" "$(resolve_base_url)"
  print_where_line "Install path" "${install_path}"
  print_where_line "Runtime path" "${runtime_path}"
  print_where_line "Backend jar" "$(configured_value AUTARK_OS_BACKEND_JAR)"
  print_where_line "Setup command" "$(configured_value AUTARK_OS_SETUP_COMMAND)"
  if has_command command; then
    print_where_line "CLI path" "$(command -v autark-os || true)"
  fi
}

print_version_line() {
  local label="$1"
  local value="$2"
  printf '%-16s %s\n' "${label}:" "${value:-unknown}"
}

version() {
  local tmp_file
  tmp_file="$(mktemp)"
  if api_get /api/system/version >"${tmp_file}" 2>/dev/null; then
    print_version_line "Version" "$(json_value version "${tmp_file}")"
    print_version_line "Build SHA" "$(json_value buildSha "${tmp_file}")"
    print_version_line "Build date" "$(json_value buildDate "${tmp_file}")"
    print_version_line "Install path" "$(json_value installPath "${tmp_file}")"
    print_version_line "Runtime path" "$(json_value runtimePath "${tmp_file}")"
    print_version_line "Backend jar" "$(json_value backendJar "${tmp_file}")"
    print_version_line "Update channel" "$(json_value updateChannel "${tmp_file}")"
    print_version_line "Update status" "$(json_value updateStatus "${tmp_file}")"
    print_version_line "Previous version" "$(configured_value AUTARK_OS_PREVIOUS_VERSION)"
    print_version_line "Previous jar" "$(configured_value AUTARK_OS_PREVIOUS_BACKEND_JAR)"
    rm -f "${tmp_file}"
    return 0
  fi
  rm -f "${tmp_file}"
  print_version_line "Version" "$(configured_value AUTARK_OS_VERSION)"
  print_version_line "Build SHA" "$(configured_value AUTARK_OS_BUILD_SHA)"
  print_version_line "Build date" "$(configured_value AUTARK_OS_BUILD_DATE)"
  print_version_line "Install path" "$(configured_value AUTARK_OS_INSTALL_DIR)"
  print_version_line "Runtime path" "$(configured_value AUTARK_OS_RUNTIME_ROOT)"
  print_version_line "Backend jar" "$(configured_value AUTARK_OS_BACKEND_JAR)"
  print_version_line "Previous version" "$(configured_value AUTARK_OS_PREVIOUS_VERSION)"
  print_version_line "Previous jar" "$(configured_value AUTARK_OS_PREVIOUS_BACKEND_JAR)"
  print_version_line "Update status" "backend unavailable"
}

doctor() {
  local json_output=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        json_output=1
        ;;
      -h|--help)
        cat <<DOCTOR_USAGE
Usage: autark-os doctor [options]

Options:
  --json     Print the backend doctor payload without human-readable status text.
  -h, --help Show this help.
DOCTOR_USAGE
        return 0
        ;;
      *)
        log "Unknown doctor option: $1"
        return 1
        ;;
    esac
    shift
  done

  local base_url
  base_url="$(resolve_base_url)"

  if [[ "${json_output}" -eq 1 ]]; then
    api_get /api/system/doctor
    printf '\n'
    return 0
  fi

  log "Checking Autark-OS at ${base_url}."

  if has_command systemctl; then
    if systemctl is-active --quiet "${SERVICE_NAME}.service"; then
      log "System service: active"
    else
      log "System service: $(systemctl is-active "${SERVICE_NAME}.service" 2>/dev/null || true)"
    fi
  else
    log "System service: systemctl unavailable"
  fi

  if api_get /api/health >/dev/null; then
    log "Backend API: reachable"
  else
    log "Backend API: not reachable"
    return 1
  fi

  if api_get /api/system/doctor >/tmp/autark-os-doctor.json 2>/dev/null; then
    if grep -q '"status":"ready"' /tmp/autark-os-doctor.json; then
      log "Device setup: ready"
    else
      log "Device setup: review needed"
      cat /tmp/autark-os-doctor.json
      printf '\n'
    fi
  elif api_get /api/system/setup-status >/tmp/autark-os-setup-status.json; then
    log "Host setup: legacy setup status"
    cat /tmp/autark-os-setup-status.json
    printf '\n'
  else
    log "Device setup: unavailable"
    return 1
  fi

  if api_get /api/discover/apps >/dev/null; then
    log "Marketplace catalog: reachable"
  else
    log "Marketplace catalog: unavailable"
    return 1
  fi

  if api_get /api/activity?limit=1 >/dev/null; then
    log "Activity log: reachable"
  else
    log "Activity log: unavailable"
    return 1
  fi

  log "Open Autark-OS: ${base_url}"
}

setup() {
  local non_interactive=0
  local print_next_step=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --non-interactive)
        non_interactive=1
        ;;
      --print-next-step)
        print_next_step=1
        ;;
      -h|--help)
        cat <<SETUP_USAGE
Usage: autark-os setup [options]

Options:
  --non-interactive  Complete setup using current backend defaults.
  --print-next-step  Print the browser URL and support command without changing setup state.
  -h, --help         Show this help.
SETUP_USAGE
        return 0
        ;;
      *)
        log "Unknown setup option: $1"
        return 1
        ;;
    esac
    shift
  done

  if [[ "${print_next_step}" -eq 1 ]]; then
    print_setup_next_step
    return 0
  fi

  local base_url
  local onboarding_file
  local doctor_file
  base_url="$(resolve_base_url)"
  onboarding_file="$(mktemp)"
  doctor_file="$(mktemp)"

  if ! api_get /api/system/onboarding >"${onboarding_file}" 2>/dev/null; then
    rm -f "${onboarding_file}" "${doctor_file}"
    log "Backend is not reachable at ${base_url}."
    if has_command systemctl; then
      log "Service state: $(systemctl is-active "${SERVICE_NAME}.service" 2>/dev/null || true)"
    fi
    log "Try:"
    log "  autark-os doctor"
    log "  autark-os status"
    log "  autark-os logs"
    return 1
  fi

  api_get /api/system/doctor >"${doctor_file}" 2>/dev/null || cp "${onboarding_file}" "${doctor_file}"

  local status
  local device_name
  local runtime_path
  local backup_destination
  local tailscale_connected
  local automatic_backups
  local lan_url
  status="$(json_value status "${onboarding_file}")"
  device_name="$(json_value deviceName "${onboarding_file}")"
  runtime_path="$(json_value runtimePath "${onboarding_file}")"
  backup_destination="$(json_value backupDestination "${onboarding_file}")"
  tailscale_connected="$(json_bool tailscaleConnected "${onboarding_file}")"
  automatic_backups="$(json_bool automaticBackupsEnabled "${onboarding_file}")"
  lan_url="$(json_value lanUrl "${doctor_file}")"
  [[ -n "${lan_url}" ]] || lan_url="${base_url}"

  log "Autark-OS first-boot setup"
  log "Current status: ${status:-unknown}"
  log "Browser URL: ${lan_url}"
  log "Runtime data: ${runtime_path:-unknown}"

  if [[ "${status}" == "complete" && "${non_interactive}" -eq 0 ]]; then
    if ! confirm_default_yes "Setup is already complete. Review and save it again?"; then
      print_setup_next_step
      rm -f "${onboarding_file}" "${doctor_file}"
      return 0
    fi
  fi

  if [[ "${non_interactive}" -eq 0 ]]; then
    printf '\nDevice readiness:\n'
    if grep -q '"status":"warning"' "${doctor_file}"; then
      log "Some setup checks need review. Run 'autark-os doctor' for full details."
    else
      log "Core setup checks look ready."
    fi
    printf '\n'
    device_name="$(read_default "Device name" "${device_name:-Autark-OS}")"
    if [[ "${tailscale_connected}" == "true" ]]; then
      log "Tailscale is connected. Private app links can be created."
    else
      log "Tailscale is not connected yet. Private links can be finished later from Network."
      log "If you want private access now, run: sudo tailscale up"
    fi
    log "Runtime storage is currently: ${runtime_path:-unknown}"
    backup_destination="$(read_default "Backup destination" "${backup_destination:-${runtime_path}/backups}")"
    if confirm_default_yes "Turn on routine backups?"; then
      automatic_backups=true
    else
      automatic_backups=false
    fi
  fi

  local recommended=()
  if [[ "${non_interactive}" -eq 1 ]]; then
    while IFS= read -r app_id; do
      recommended+=("${app_id}")
    done < <(json_array_strings recommendedApps "${onboarding_file}")
    [[ "${#recommended[@]}" -gt 0 ]] || recommended=(vaultwarden jellyfin homepage)
  else
    printf '\nRecommended starter apps:\n'
    local app_id
    for app_id in vaultwarden jellyfin homepage; do
      if confirm_default_yes "Recommend ${app_id}?"; then
        recommended+=("${app_id}")
      fi
    done
  fi

  local body
  body="$(printf '{"status":"in_progress","currentStep":5,"deviceName":"%s","backupDestination":"%s","automaticBackupsEnabled":%s,"recommendedApps":%s,"completedSteps":["device","doctor","tailscale","storage","backups","apps"]}' \
    "$(json_escape "${device_name:-Autark-OS}")" \
    "$(json_escape "${backup_destination:-}")" \
    "${automatic_backups:-true}" \
    "$(json_list "${recommended[@]}")")"

  if ! api_put /api/system/onboarding "${body}" >/dev/null; then
    rm -f "${onboarding_file}" "${doctor_file}"
    log "Could not save setup choices."
    return 1
  fi
  if ! api_post /api/system/onboarding/complete '{}' >/dev/null; then
    rm -f "${onboarding_file}" "${doctor_file}"
    log "Could not mark setup complete."
    return 1
  fi

  rm -f "${onboarding_file}" "${doctor_file}"
  log "Setup complete."
  print_setup_next_step
}

case "${1:-help}" in
  install)
    shift || true
    install_command "$@"
    ;;
  doctor)
    shift || true
    doctor "$@"
    ;;
  setup)
    shift || true
    setup "$@"
    ;;
  admin)
    shift || true
    admin_command "$@"
    ;;
  repair)
    shift || true
    repair_command "$@"
    ;;
  update)
    shift || true
    update_command "$@"
    ;;
  uninstall)
    shift || true
    uninstall_command "$@"
    ;;
  support-bundle)
    shift || true
    support_bundle_command "$@"
    ;;
  where)
    where_info
    ;;
  status)
    systemctl status "${SERVICE_NAME}.service" --no-pager
    ;;
  logs)
    shift || true
    logs_command "$@"
    ;;
  start)
    sudo systemctl start "${SERVICE_NAME}.service"
    ;;
  stop)
    sudo systemctl stop "${SERVICE_NAME}.service"
    ;;
  restart)
    sudo systemctl restart "${SERVICE_NAME}.service"
    ;;
  version)
    version
    ;;
  port)
    resolve_port
    ;;
  url)
    resolve_base_url
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
