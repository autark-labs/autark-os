{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.autark-os.org/extensions/v1/ui-manifest.schema.json",
  "title": "Extension UI manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "extensionId",
    "componentVersion",
    "entrypoint",
    "entrypointSha256",
    "surfaces"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "extensionId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,127}$"
    },
    "componentVersion": {
      "$ref": "https://contracts.autark-os.org/pro/v1/common-v1.schema.json#/$defs/semver"
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]{1,128}$"
    },
    "entrypointSha256": {
      "$ref": "https://contracts.autark-os.org/pro/v1/common-v1.schema.json#/$defs/digest"
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9.-]{1,127}$"
      }
    }
  }
}
