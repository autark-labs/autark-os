{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.autark-os.org/pro/v1/agent-status.schema.json",
  "title": "AgentStatus v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "componentVersion",
    "apiVersion",
    "supportedSnapshotSchemaVersions",
    "supportedSurfaceSchemaVersions",
    "state",
    "ready",
    "reasonCode",
    "startedAt"
  ],
  "properties": {
    "schemaVersion": {
      "$ref": "common-v1.schema.json#/$defs/schemaVersion"
    },
    "componentVersion": {
      "$ref": "common-v1.schema.json#/$defs/semver"
    },
    "apiVersion": {
      "const": "1"
    },
    "supportedSnapshotSchemaVersions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[0-9]+$"
      }
    },
    "supportedSurfaceSchemaVersions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[0-9]+$"
      }
    },
    "state": {
      "enum": ["alive", "ready", "incompatible", "degraded"]
    },
    "ready": {
      "type": "boolean"
    },
    "reasonCode": {
      "$ref": "common-v1.schema.json#/$defs/errorCode"
    },
    "startedAt": {
      "$ref": "common-v1.schema.json#/$defs/dateTime"
    }
  }
}
